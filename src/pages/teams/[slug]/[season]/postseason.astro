---
import DriversFieldedTable from '../../../../components/driver/DriversFieldedTable.astro';
import Base from '../../../../layouts/Base.astro';
import { teamLinkAt, driverLinkAt, raceLinkAt } from '../../../../lib/nav';
import { pitForPostseason, resolveAsOfRaceNumber } from '../../../../lib/point-in-time';
import { formatPts, stripYearPrefix } from '../../../../lib/format';
import {
  getTeamBySlug,
  getTeamCareerStats,
  getTeamDriversFielded,
  getSeasonBookends,
} from '../../../../lib/queries';
import type { PageContext } from '../../../../lib/types';
import { emojify } from '../../../../lib/ui/emojify';

export const prerender = false;

const { slug, season: seasonStr } = Astro.params;
const season = Number(seasonStr);

const team = slug && (await getTeamBySlug(slug));
if (!team) throw new Error(`Team not found: ${slug}`);

const bookends = await getSeasonBookends(season);
const pit = pitForPostseason(season);
const asOf = resolveAsOfRaceNumber(pit, bookends);
const lastRaceSlug = stripYearPrefix(bookends.lastSlug, season);

const [stats, driversFielded] = await Promise.all([
  getTeamCareerStats(team.id, asOf),
  getTeamDriversFielded(team.id, asOf),
]);

const pageContext: PageContext = {
  kind: 'team-postseason',
  season,
  raceCount: bookends.raceCount,
  teamName: team.name,
  teamSlug: slug,
  prevRaceSlug: lastRaceSlug,
};

const title = `${team.name} — ${season} Postseason`;
const description = `${team.name}'s stats after the ${season} season: ${stats.wins} wins, ${stats.podiums} podiums, ${stats.championships} constructors' title${stats.championships !== 1 ? 's' : ''}.`;
---

<Base
  title={title}
  description={description}
  canonical={teamLinkAt(slug, pit)}
  {pageContext}
>
  <div class="mb-4">
    <a
      href={raceLinkAt(pit)}
      class="text-sm text-fg-muted hover:text-accent transition-colors"
    >
      &larr; {season} Season
    </a>
  </div>

  <div class="mb-6">
    {
      team.primary_color && (
        <div class="h-1 w-12 rounded-full mb-3" style={`background:${team.primary_color}`} />
      )
    }
    <h1 class="text-2xl font-bold text-fg">{team.name}</h1>
    {team.nationality && <p class="text-sm text-fg-muted mt-1">{emojify(team.nationality)}</p>}
  </div>

  <section class="mb-4">
    <h2 class="mb-4 text-lg font-semibold text-fg">Stats After the Season</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">
      {
        [
          { label: 'Race Entries', value: stats.entries },
          { label: 'Wins', value: stats.wins },
          { label: 'Podiums', value: stats.podiums },
          { label: 'Poles', value: stats.poles },
          { label: 'Fastest Laps', value: stats.fastest_laps },
          { label: 'Career Points', value: formatPts(stats.points) },
          { label: "Constructors' Titles", value: stats.championships },
          { label: 'Drivers Fielded', value: stats.drivers_fielded },
        ].map(({ label, value }) => (
          <div class="rounded-lg border border-border bg-bg-alt p-3">
            <div class="text-xs text-fg-muted uppercase tracking-wide">{label}</div>
            <div
              class={`text-xl font-bold mt-1 ${label === "Constructors' Titles" && Number(value) > 0 ? 'text-accent' : 'text-fg'}`}
            >
              {value}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <DriversFieldedTable
    drivers={driversFielded}
    driverHref={(dSlug) => driverLinkAt(dSlug, pit)}
  />
</Base>
