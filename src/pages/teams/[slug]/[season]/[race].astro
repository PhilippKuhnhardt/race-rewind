---
import Base from '../../../../layouts/Base.astro';
import DriversFieldedTable from '../../../../components/driver/DriversFieldedTable.astro';
import {
  getAllTeamRacePairs,
  getAllRacesBySeason,
  getTeamBySlug,
  getRaceBySlug,
  getTeamCareerStats,
  getTeamStandingBeforeRace,
  getTeamDriversFielded,
} from '../../../../lib/queries';
import { formatPts, stripYearPrefix, teamLink, raceLink, driverLink } from '../../../../lib/format';
import type { PageContext } from '../../../../lib/types';

export async function getStaticPaths() {
  return (await getAllTeamRacePairs()).map((p) => ({
    params: { slug: p.team_slug, season: String(p.season), race: p.race_slug },
  }));
}

const { slug, season, race: raceSlug } = Astro.params;

const team = await getTeamBySlug(slug);
if (!team) throw new Error(`Team not found: ${slug}`);

const fullSlug = `${season}-${raceSlug}`;
const race = await getRaceBySlug(fullSlug);
if (!race) throw new Error(`Race not found: ${fullSlug}`);

const raceNavSlug = stripYearPrefix(race.slug, race.season);
const [stats, standing, driversFielded, { byseason }] = await Promise.all([
  getTeamCareerStats(team.id, race.race_number),
  getTeamStandingBeforeRace(team.id, race.race_number),
  getTeamDriversFielded(team.id, race.race_number),
  getAllRacesBySeason(),
]);

const seasonRaces = byseason[race.season] ?? [];
const idx = seasonRaces.findIndex((r) => r.slug === raceNavSlug);
const prevRaceSlug = idx > 0 ? seasonRaces[idx - 1].slug : undefined;
const nextRaceSlug = idx < seasonRaces.length - 1 ? seasonRaces[idx + 1].slug : undefined;

const pageContext: PageContext = {
  kind: 'team-race',
  season: race.season,
  raceName: race.name,
  raceSlug: raceNavSlug,
  teamName: team.name,
  teamSlug: slug,
  prevRaceSlug,
  nextRaceSlug,
};

const title = `${team.name} — ${race.season} ${race.name}`;
const description = `${team.name}'s career going into the ${race.season} ${race.name}: ${stats.wins} wins, ${stats.podiums} podiums, ${stats.championships} constructors' title${stats.championships !== 1 ? 's' : ''}.`;
---

<Base title={title} description={description} canonical={teamLink(slug, season, raceSlug)} {pageContext}>
  <div class="mb-4">
    <a href={raceLink(race.season, raceNavSlug)} class="text-sm text-fg-muted hover:text-accent transition-colors">
      &larr; {race.season} {race.name}
    </a>
  </div>

  <div class="mb-6">
    {team.primary_color && (
      <div class="h-1 w-12 rounded-full mb-3" style={`background:${team.primary_color}`} />
    )}
    <h1 class="text-2xl font-bold text-fg">{team.name}</h1>
    {team.nationality && (
      <p class="text-sm text-fg-muted mt-1">{team.nationality}</p>
    )}
  </div>

  <section class="mb-6">
    <h2 class="mb-4 text-lg font-semibold text-fg">Going Into This Race</h2>
    {standing ? (
      <div class="overflow-x-auto rounded-lg border border-border">
        <table class="w-full border-collapse text-sm">
          <thead>
            <tr>
              <th class="bg-bg-alt px-3 py-2.5 text-right text-xs font-semibold uppercase tracking-wide text-fg-muted border-b border-border whitespace-nowrap">Championship Pos</th>
              <th class="bg-bg-alt px-3 py-2.5 text-right text-xs font-semibold uppercase tracking-wide text-fg-muted border-b border-border whitespace-nowrap">Points</th>
              <th class="bg-bg-alt px-3 py-2.5 text-right text-xs font-semibold uppercase tracking-wide text-fg-muted border-b border-border whitespace-nowrap">Wins</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="px-3 py-2.5 text-right tabular-nums font-semibold text-accent">{standing.position ?? '—'}</td>
              <td class="px-3 py-2.5 text-right tabular-nums text-fg">{formatPts(standing.points)}</td>
              <td class="px-3 py-2.5 text-right tabular-nums text-fg">{standing.win_count}</td>
            </tr>
          </tbody>
        </table>
      </div>
    ) : (
      <p class="text-sm text-fg-muted">First race of the season — championship not yet started.</p>
    )}
  </section>

  <DriversFieldedTable
    drivers={driversFielded}
    driverHref={(dSlug) => driverLink(dSlug, race.season, raceNavSlug)}
  />

  <section>
    <h2 class="mb-4 text-lg font-semibold text-fg">Career Going Into This Race</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">
      {[
        { label: 'Race Entries', value: stats.entries },
        { label: 'Wins', value: stats.wins },
        { label: 'Podiums', value: stats.podiums },
        { label: 'Poles', value: stats.poles },
        { label: 'Fastest Laps', value: stats.fastest_laps },
        { label: 'Career Points', value: formatPts(stats.points) },
        { label: "Constructors' Titles", value: stats.championships },
        { label: 'Drivers Fielded', value: stats.drivers_fielded },
      ].map(({ label, value }) => (
        <div class="rounded-lg border border-border bg-bg-alt p-3">
          <div class="text-xs text-fg-muted uppercase tracking-wide">{label}</div>
          <div class={`text-xl font-bold mt-1 ${label === "Constructors' Titles" && Number(value) > 0 ? 'text-accent' : 'text-fg'}`}>{value}</div>
        </div>
      ))}
    </div>
  </section>
</Base>
