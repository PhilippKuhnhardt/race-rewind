---
import Base from '../../../layouts/Base.astro';
import DriverPickerForm from '../../../components/compare/DriverPickerForm.svelte';
import PageHeader from '../../../components/layout/PageHeader.astro';
import { getAllDriversForPicker, getRaceBySlug, getAllRacesBySeason, getSeasonBounds } from '../../../lib/queries';
import { stripYearPrefix } from '../../../lib/format';
import type { PageContext } from '../../../lib/types';

export const prerender = false;

const { season: seasonStr, race: raceSlug } = Astro.params;
const prefill = Astro.url.searchParams.get('prefill') ?? undefined;
const season = Number(seasonStr);

const isBoundary = raceSlug === 'preseason' || raceSlug === 'postseason';

const [drivers, { byseason }] = await Promise.all([
  getAllDriversForPicker(),
  getAllRacesBySeason(),
]);

const seasonRaces = byseason[season] ?? [];

let pageContext: PageContext;
let title: string;
let subtitle: string;
let canonical: string;

if (isBoundary) {
  const bounds = season && (await getSeasonBounds(season));
  if (!bounds) throw new Error(`Season not found: ${season}`);

  if (raceSlug === 'preseason') {
    pageContext = { kind: 'preseason', season, raceCount: bounds.raceCount, firstRaceSlug: bounds.firstRaceSlug };
    title = `Compare Drivers — ${season} Preseason`;
    subtitle = `${season} — Before Round 1`;
  } else {
    pageContext = { kind: 'postseason', season, raceCount: bounds.raceCount, prevRaceSlug: bounds.lastRaceSlug, inProgressRound: null };
    title = `Compare Drivers — ${season} Postseason`;
    subtitle = `${season} — End of Season`;
  }
  canonical = `/compare/${season}/${raceSlug}/`;
} else {
  const fullSlug = `${seasonStr}-${raceSlug}`;
  const race = seasonStr && raceSlug && (await getRaceBySlug(fullSlug));
  if (!race) throw new Error(`Race not found: ${fullSlug}`);

  const raceNavSlug = stripYearPrefix(race.slug, race.season);
  const idx = seasonRaces.findIndex((r) => r.slug === raceNavSlug);
  const prevRaceSlug = idx > 0 ? seasonRaces[idx - 1].slug : undefined;
  const nextRaceSlug = idx < seasonRaces.length - 1 ? seasonRaces[idx + 1].slug : undefined;

  pageContext = {
    kind: 'race',
    season: race.season,
    round: race.round,
    raceCount: seasonRaces.length,
    raceDate: race.date,
    raceName: race.name,
    raceSlug: raceNavSlug,
    prevRaceSlug,
    nextRaceSlug,
  };
  title = `Compare Drivers — ${race.season} ${race.name}`;
  subtitle = `${race.season} ${race.name}`;
  canonical = `/compare/${race.season}/${raceNavSlug}/`;
}
---

<Base {title} description={`Compare any two F1 drivers at the ${subtitle}.`} {canonical} {pageContext}>
  <PageHeader title="Compare Drivers" {subtitle} />
  <DriverPickerForm
    client:load
    {season}
    raceSlug={raceSlug!}
    {drivers}
    {prefill}
  />
</Base>
