---
import Base from '../../../layouts/Base.astro';
import {
  getAllDriverRacePairs,
  getDriverBySlug,
  getDriverCareerStats,
  getDriverSeasonFirstRaces,
} from '../../../lib/queries';
import { formatPts, driverLink } from '../../../lib/format';

export async function getStaticPaths() {
  const pairs = await getAllDriverRacePairs();
  const slugs = [...new Set(pairs.map((p) => p.driver_slug))];
  return slugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;

const driver = await getDriverBySlug(slug);
if (!driver) throw new Error(`Driver not found: ${slug}`);

const [stats, seasonFirstRaces] = await Promise.all([
  getDriverCareerStats(driver.id, 999999),
  getDriverSeasonFirstRaces(driver.id),
]);

const seasons = Object.keys(seasonFirstRaces)
  .map(Number)
  .sort((a, b) => b - a);

const title = `${driver.full_name} — Career Overview`;
const description = `${driver.full_name}: ${stats.starts} F1 starts, ${stats.wins} wins, ${stats.championships} championship${stats.championships !== 1 ? 's' : ''}.`;
---

<Base title={title} description={description} canonical={`/drivers/${slug}/`}>
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-fg">{driver.full_name}</h1>
    <p class="text-sm text-fg-muted mt-1">
      {
        [
          driver.nationality,
          driver.date_of_birth ? `b. ${driver.date_of_birth}` : null,
          driver.abbreviation,
          driver.permanent_car_number ? `#${driver.permanent_car_number}` : null,
        ]
          .filter(Boolean)
          .join(' · ')
      }
    </p>
  </div>

  <section class="mb-6">
    <h2 class="mb-4 text-lg font-semibold text-fg">Career Statistics</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">
      {[
        { label: 'Starts', value: stats.starts },
        { label: 'Wins', value: stats.wins },
        { label: 'Podiums', value: stats.podiums },
        { label: 'Poles', value: stats.poles },
        { label: 'Fastest Laps', value: stats.fastest_laps },
        { label: 'Career Points', value: formatPts(stats.points) },
        { label: 'Championships', value: stats.championships },
        { label: 'Seasons', value: seasons.length },
      ].map(({ label, value }) => (
        <div class="rounded-lg border border-border bg-bg-alt p-3">
          <div class="text-xs text-fg-muted uppercase tracking-wide">{label}</div>
          <div class={`text-xl font-bold mt-1 ${label === 'Championships' && Number(value) > 0 ? 'text-accent' : 'text-fg'}`}>{value}</div>
        </div>
      ))}
    </div>
  </section>

  <section>
    <h2 class="mb-4 text-lg font-semibold text-fg">Seasons</h2>
    <div class="overflow-x-auto rounded-lg border border-border">
      <table class="w-full border-collapse text-sm">
        <thead>
          <tr>
            <th class="bg-bg-alt px-3 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-fg-muted border-b border-border whitespace-nowrap">Season</th>
          </tr>
        </thead>
        <tbody>
          {seasons.map((season) => {
            const firstRaceSlug = seasonFirstRaces[season];
            return (
              <tr class="border-b border-border last:border-0 hover:bg-bg-hover transition-colors">
                <td class="px-3 py-2.5">
                  <a href={driverLink(slug, String(season), firstRaceSlug)} class="text-accent hover:underline font-medium">
                    {season}
                  </a>
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  </section>
</Base>
