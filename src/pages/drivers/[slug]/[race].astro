---
import Base from '../../../layouts/Base.astro';
import {
  getAllDriverRacePairs,
  getDriverBySlug,
  getRaceBySlug,
  getDriverRaceEntry,
  getDriverCareerStats,
  getDriverStandingAsOf,
} from '../../../lib/queries';
import { formatPos, formatPts, stripYearPrefix } from '../../../lib/format';

export function getStaticPaths() {
  return getAllDriverRacePairs().map((p) => ({
    params: { slug: p.driver_slug, race: p.race_slug },
  }));
}

const { slug, race: raceSlug } = Astro.params;

const driver = getDriverBySlug(slug);
if (!driver) throw new Error(`Driver not found: ${slug}`);

const race = getRaceBySlug(raceSlug);
if (!race) throw new Error(`Race not found: ${raceSlug}`);

const raceUrlSlug = stripYearPrefix(race.slug, race.season);
const entry = getDriverRaceEntry(driver.id, race.race_number);
const stats = getDriverCareerStats(driver.id, race.race_number);
const standing = getDriverStandingAsOf(driver.id, race.race_number);

const title = `${driver.full_name} — ${race.season} ${race.name}`;
const description = `${driver.full_name}'s stats as of the ${race.season} ${race.name}: ${stats.wins} career wins, ${stats.podiums} podiums, ${stats.championships} world championship${stats.championships !== 1 ? 's' : ''}.`;
---

<Base
  title={title}
  description={description}
  canonical={`/drivers/${slug}/${raceSlug}/`}
  navSeason={race.season}
  navRaceSlug={raceUrlSlug}
>
  <a class="back-link" href={`/seasons/${race.season}/${raceUrlSlug}/`}>
    &larr; {race.season}
    {race.name}
  </a>

  <div class="page-header">
    <h1>{driver.full_name}</h1>
    <p class="meta">
      {
        [
          driver.nationality,
          driver.date_of_birth ? `b. ${driver.date_of_birth}` : null,
          driver.abbreviation,
          driver.permanent_car_number ? `#${driver.permanent_car_number}` : null,
        ]
          .filter(Boolean)
          .join(' · ')
      }
    </p>
  </div>

  {
    entry && (
      <section class="section">
        <h2>This Race</h2>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Team</th>
                <th class="num">Grid</th>
                <th class="num">Finish</th>
                <th class="num">Pts</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>{entry.team_name}</td>
                <td class="num">{entry.grid ?? '—'}</td>
                <td class="num pos">{formatPos(entry.position)}</td>
                <td class="num">{formatPts(entry.points)}</td>
                <td class:list={[{ dnf: !entry.is_classified }]}>
                  {entry.is_classified ? 'Finished' : (entry.detail ?? '—')}
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>
    )
  }

  <section class="section">
    <h2>Career as of This Race</h2>
    <div class="stat-grid">
      <div class="stat-card">
        <div class="stat-label">Starts</div>
        <div class="stat-value">{stats.starts}</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Wins</div>
        <div class="stat-value">{stats.wins}</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Podiums</div>
        <div class="stat-value">{stats.podiums}</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Poles</div>
        <div class="stat-value">{stats.poles}</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Fastest Laps</div>
        <div class="stat-value">{stats.fastest_laps}</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Career Points</div>
        <div class="stat-value">{formatPts(stats.points)}</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Championships</div>
        <div class="stat-value">{stats.championships}</div>
      </div>
    </div>
  </section>

  {
    standing && (
      <section class="section">
        <h2>This Season</h2>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th class="num">Championship Pos</th>
                <th class="num">Points</th>
                <th class="num">Wins</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td class="num pos">{standing.position ?? '—'}</td>
                <td class="num">{formatPts(standing.points)}</td>
                <td class="num">{standing.win_count}</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>
    )
  }
</Base>
