---
import DriverSeasonOverviewTable from '../../../../components/driver/DriverSeasonOverviewTable.astro';
import TeamsDrivenTable from '../../../../components/team/TeamsDrivenTable.astro';
import Base from '../../../../layouts/Base.astro';
import { driverLinkAt, teamLinkAt, raceLinkAt } from '../../../../lib/nav';
import { pitForPreseason, resolveAsOfRaceNumber } from '../../../../lib/point-in-time';
import { NOINDEX_FOLLOW, setLongEdgeCache, setNoindexFollow } from '../../../../lib/response';
import { formatPts, stripYearPrefix } from '../../../../lib/format';
import {
  getDriverBySlug,
  getDriverCareerStats,
  getDriverPriorSeasons,
  getDriverSeasonOverview,
  getDriverTeamsDriven,
  getSeasonBookends,
} from '../../../../lib/queries';
import type { PageContext } from '../../../../lib/types';
import { emojify } from '../../../../lib/ui/emojify';

export const prerender = false;

setNoindexFollow(Astro.response.headers);
setLongEdgeCache(Astro.response.headers);

const { slug, season: seasonStr } = Astro.params;
const season = Number(seasonStr);

const driver = slug && (await getDriverBySlug(slug));
if (!driver) throw new Error(`Driver not found: ${slug}`);

const bookends = await getSeasonBookends(season);
const pit = pitForPreseason(season);
const asOf = resolveAsOfRaceNumber(pit, bookends);
const firstRaceSlug = stripYearPrefix(bookends.firstSlug, season);

const [stats, seasonOverview, teamsDriven, priorSeasons] = await Promise.all([
  getDriverCareerStats(driver.id, asOf),
  getDriverSeasonOverview(driver.id, asOf),
  getDriverTeamsDriven(driver.id, asOf),
  getDriverPriorSeasons(driver.id, asOf),
]);

const pageContext: PageContext = {
  kind: 'driver-preseason',
  season,
  raceCount: bookends.raceCount,
  driverName: driver.full_name,
  driverSlug: slug,
  nextRaceSlug: firstRaceSlug,
};

const title = `${driver.full_name} — ${season} Preseason`;
const description = `${driver.full_name}'s career going into the ${season} season: ${stats.wins} wins, ${stats.podiums} podiums, ${stats.championships} championship${stats.championships !== 1 ? 's' : ''}.`;
---

<Base
  title={title}
  description={description}
  canonical={driverLinkAt(slug, pit)}
  robots={NOINDEX_FOLLOW}
  {pageContext}
>
  <div class="mb-4">
    <a
      href={raceLinkAt(pit)}
      class="text-sm text-fg-muted hover:text-accent transition-colors"
    >
      &larr; {season} Season
    </a>
  </div>

  <div class="mb-6">
    <h1 class="text-2xl font-bold text-fg">{driver.full_name}</h1>
    <p class="text-sm text-fg-muted mt-1">
      {
        [
          driver.nationality && emojify(driver.nationality),
          driver.date_of_birth ? `b. ${driver.date_of_birth}` : null,
          driver.abbreviation,
          driver.permanent_car_number ? `#${driver.permanent_car_number}` : null,
        ]
          .filter(Boolean)
          .join(' · ')
      }
    </p>
  </div>

  <section class="mb-4">
    <h2 class="mb-4 text-lg font-semibold text-fg">Career Going Into the Season</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">
      {
        [
          { label: 'Starts', value: stats.starts },
          { label: 'Wins', value: stats.wins },
          { label: 'Podiums', value: stats.podiums },
          { label: 'Poles', value: stats.poles },
          { label: 'Fastest Laps', value: stats.fastest_laps },
          { label: 'Career Points', value: formatPts(stats.points) },
          { label: 'Championships', value: stats.championships },
          { label: 'Seasons', value: priorSeasons },
        ].map(({ label, value }) => (
          <div class="rounded-lg border border-border bg-bg-alt p-3">
            <div class="text-xs text-fg-muted uppercase tracking-wide">{label}</div>
            <div
              class={`text-xl font-bold mt-1 ${label === 'Championships' && Number(value) > 0 ? 'text-accent' : 'text-fg'}`}
            >
              {value}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <DriverSeasonOverviewTable driverSlug={slug} rows={seasonOverview} {pit} />

  <TeamsDrivenTable
    teams={teamsDriven}
    teamHref={(tSlug) => teamLinkAt(tSlug, pit)}
  />
</Base>
