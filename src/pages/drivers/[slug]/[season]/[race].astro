---
import DriverSeasonOverviewTable from '../../../../components/driver/DriverSeasonOverviewTable.astro';
import TeamsDrivenTable from '../../../../components/team/TeamsDrivenTable.astro';
import Base from '../../../../layouts/Base.astro';
import { driverLink, formatPts, raceLink, stripYearPrefix, teamLink } from '../../../../lib/format';
import { pitForRace } from '../../../../lib/point-in-time';
import { NOINDEX_FOLLOW, setLongEdgeCache, setNoindexFollow } from '../../../../lib/response';
import {
  getAllRacesBySeason,
  getDriverBySlug,
  getDriverCareerStats,
  getDriverSeasonOverview,
  getDriverPriorSeasons,
  getDriverTeamsDriven,
  getRaceBySlug,
} from '../../../../lib/queries';
import type { PageContext } from '../../../../lib/types';
import { emojify } from '../../../../lib/ui/emojify';

export const prerender = false;

setNoindexFollow(Astro.response.headers);
setLongEdgeCache(Astro.response.headers);

const { slug, season, race: raceSlug } = Astro.params;

const driver = slug && (await getDriverBySlug(slug));
if (!driver) throw new Error(`Driver not found: ${slug}`);

const fullSlug = `${season}-${raceSlug}`;
const race = season && raceSlug && (await getRaceBySlug(fullSlug));
if (!race) throw new Error(`Race not found: ${fullSlug}`);

const raceNavSlug = stripYearPrefix(race.slug, race.season);
const pit = pitForRace(race, raceNavSlug);
const [stats, seasonOverview, teamsDriven, { byseason }, priorSeasons] = await Promise.all([
  getDriverCareerStats(driver.id, race.race_number),
  getDriverSeasonOverview(driver.id, race.race_number),
  getDriverTeamsDriven(driver.id, race.race_number),
  getAllRacesBySeason(),
  getDriverPriorSeasons(driver.id, race.race_number),
]);

const seasonRaces = byseason[race.season] ?? [];
const idx = seasonRaces.findIndex((r) => r.slug === raceNavSlug);
const prevRaceSlug = idx > 0 ? seasonRaces[idx - 1].slug : 'preseason';
const nextRaceSlug = idx < seasonRaces.length - 1 ? seasonRaces[idx + 1].slug : 'postseason';

const pageContext: PageContext = {
  kind: 'driver-race',
  season: race.season,
  raceName: race.name,
  raceSlug: raceNavSlug,
  driverName: driver.full_name,
  driverSlug: slug,
  prevRaceSlug,
  nextRaceSlug,
};

const title = `${driver.full_name} — ${race.season} ${race.name}`;
const description = `${driver.full_name}'s career going into the ${race.season} ${race.name}: ${stats.wins} wins, ${stats.podiums} podiums, ${stats.championships} championship${stats.championships !== 1 ? 's' : ''}.`;
---

<Base
  title={title}
  description={description}
  canonical={driverLink(slug, season, raceSlug)}
  robots={NOINDEX_FOLLOW}
  {pageContext}
>
  <div class="mb-4">
    <a
      href={raceLink(race.season, raceNavSlug)}
      class="text-sm text-fg-muted hover:text-accent transition-colors"
    >
      &larr; {race.season}
      {race.name}
    </a>
  </div>

  <div class="mb-6">
    <h1 class="text-2xl font-bold text-fg">{driver.full_name}</h1>
    <p class="text-sm text-fg-muted mt-1">
      {
        [
          driver.nationality && emojify(driver.nationality),
          driver.date_of_birth ? `b. ${driver.date_of_birth}` : null,
          driver.abbreviation,
          driver.permanent_car_number ? `#${driver.permanent_car_number}` : null,
        ]
          .filter(Boolean)
          .join(' · ')
      }
    </p>
  </div>

  <section class="mb-4">
    <h2 class="mb-4 text-lg font-semibold text-fg">Career Going Into This Race</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">
      {
        [
          { label: 'Starts', value: stats.starts },
          { label: 'Wins', value: stats.wins },
          { label: 'Podiums', value: stats.podiums },
          { label: 'Poles', value: stats.poles },
          { label: 'Fastest Laps', value: stats.fastest_laps },
          { label: 'Career Points', value: formatPts(stats.points) },
          { label: 'Championships', value: stats.championships },
          { label: 'Seasons', value: priorSeasons },
        ].map(({ label, value }) => (
          <div class="rounded-lg border border-border bg-bg-alt p-3">
            <div class="text-xs text-fg-muted uppercase tracking-wide">{label}</div>
            <div
              class={`text-xl font-bold mt-1 ${label === 'Championships' && Number(value) > 0 ? 'text-accent' : 'text-fg'}`}
            >
              {value}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <DriverSeasonOverviewTable driverSlug={slug} rows={seasonOverview} {pit} />

  <TeamsDrivenTable
    teams={teamsDriven}
    teamHref={(tSlug) => teamLink(tSlug, race.season, raceNavSlug)}
  />
</Base>
