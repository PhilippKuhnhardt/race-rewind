---
import Base from '../../../../layouts/Base.astro';
import {
  getAllDriverRacePairs,
  getDriverBySlug,
  getRaceBySlug,
  getDriverCareerStats,
  getDriverStandingBeforeRace,
  getDriverSeasonFirstRaces,
} from '../../../../lib/queries';
import { formatPts, stripYearPrefix } from '../../../../lib/format';

export async function getStaticPaths() {
  return (await getAllDriverRacePairs()).map((p) => ({
    params: { slug: p.driver_slug, season: String(p.season), race: p.race_slug },
  }));
}

const { slug, season, race: raceSlug } = Astro.params;

const driver = await getDriverBySlug(slug);
if (!driver) throw new Error(`Driver not found: ${slug}`);

const fullSlug = `${season}-${raceSlug}`;
const race = await getRaceBySlug(fullSlug);
if (!race) throw new Error(`Race not found: ${fullSlug}`);

const raceNavSlug = stripYearPrefix(race.slug, race.season);
const [stats, standing, seasonFirstRaces] = await Promise.all([
  getDriverCareerStats(driver.id, race.race_number),
  getDriverStandingBeforeRace(driver.id, race.race_number, race.season),
  getDriverSeasonFirstRaces(driver.id),
]);

const title = `${driver.full_name} — ${race.season} ${race.name}`;
const description = `${driver.full_name}'s career going into the ${race.season} ${race.name}: ${stats.wins} wins, ${stats.podiums} podiums, ${stats.championships} championship${stats.championships !== 1 ? 's' : ''}.`;
---

<Base
  title={title}
  description={description}
  canonical={`/drivers/${slug}/${season}/${raceSlug}/`}
  navSeason={race.season}
  navContext={{ kind: 'driver', entitySlug: slug, entitySeasons: seasonFirstRaces }}
>
  <a class="back-link" href={`/seasons/${race.season}/${raceNavSlug}/`}>
    &larr; {race.season}
    {race.name}
  </a>

  <div class="page-header">
    <h1>{driver.full_name}</h1>
    <p class="meta">
      {
        [
          driver.nationality,
          driver.date_of_birth ? `b. ${driver.date_of_birth}` : null,
          driver.abbreviation,
          driver.permanent_car_number ? `#${driver.permanent_car_number}` : null,
        ]
          .filter(Boolean)
          .join(' · ')
      }
    </p>
  </div>

  {
    standing ? (
      <section class="section">
        <h2>Going Into This Race</h2>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th class="num">Championship Pos</th>
                <th class="num">Points</th>
                <th class="num">Wins</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td class="num pos">{standing.position ?? '—'}</td>
                <td class="num">{formatPts(standing.points)}</td>
                <td class="num">{standing.win_count}</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>
    ) : (
      <section class="section">
        <h2>Going Into This Race</h2>
        <p class="section-note">First race of the season — championship not yet started.</p>
      </section>
    )
  }

  <section class="section">
    <h2>Career Going Into This Race</h2>
    <div class="stat-grid">
      <div class="stat-card">
        <div class="stat-label">Starts</div>
        <div class="stat-value">{stats.starts}</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Wins</div>
        <div class="stat-value">{stats.wins}</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Podiums</div>
        <div class="stat-value">{stats.podiums}</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Poles</div>
        <div class="stat-value">{stats.poles}</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Fastest Laps</div>
        <div class="stat-value">{stats.fastest_laps}</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Career Points</div>
        <div class="stat-value">{formatPts(stats.points)}</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Championships</div>
        <div class="stat-value">{stats.championships}</div>
      </div>
    </div>
  </section>
</Base>
