---
import Base from '../../../layouts/Base.astro';
import StatsDriversView from '../../../components/driver/StatsDriversView.astro';
import { getAllRacesBySeason, getAllRaces, getAllDriverCareerStatsAsOf, getActiveGridStats } from '../../../lib/queries';
import type { PageContext } from '../../../lib/types';
import { pitForPreseason, pitForPostseason } from '../../../lib/point-in-time';
import type { PointInTime } from '../../../lib/point-in-time';

export async function getStaticPaths() {
  const [{ seasons, byseason }, allRaces] = await Promise.all([
    getAllRacesBySeason(),
    getAllRaces(),
  ]);

  const raceNumMap = new Map<string, number>();
  const raceDateMap = new Map<string, string>();
  for (const r of allRaces) {
    const key = `${r.season}/${r.race_slug}`;
    raceNumMap.set(key, r.race_number);
    raceDateMap.set(key, r.date);
  }

  const paths: object[] = [];

  for (const season of seasons) {
    const seasonRaces = byseason[season] ?? [];
    const raceCount = seasonRaces.length;
    const firstRace = seasonRaces[0];
    const lastRace = seasonRaces[seasonRaces.length - 1];
    const firstRn = raceNumMap.get(`${season}/${firstRace?.slug}`);
    const lastRn = raceNumMap.get(`${season}/${lastRace?.slug}`);
    if (!firstRn || !lastRn) continue;

    const firstDate = raceDateMap.get(`${season}/${firstRace?.slug}`) ?? '';
    const lastDate = raceDateMap.get(`${season}/${lastRace?.slug}`) ?? '';

    // preseason
    paths.push({
      params: { season: String(season), chain: 'preseason' },
      props: {
        season,
        raceCount,
        chainSlug: 'preseason',
        raceName: null,
        beforeRaceNumber: firstRn,
        participantRaceNumber: firstRn,
        atDate: firstDate,
        driverLinkRaceSlug: firstRace.slug,
        prevChainSlug: undefined,
        nextChainSlug: firstRace.slug,
      },
    });

    // individual races
    for (let i = 0; i < seasonRaces.length; i++) {
      const race = seasonRaces[i];
      const rn = raceNumMap.get(`${season}/${race.slug}`);
      const rd = raceDateMap.get(`${season}/${race.slug}`) ?? '';
      if (!rn) continue;
      paths.push({
        params: { season: String(season), chain: race.slug },
        props: {
          season,
          raceCount,
          chainSlug: race.slug,
          raceName: race.name,
          beforeRaceNumber: rn,
          participantRaceNumber: rn,
          atDate: rd,
          driverLinkRaceSlug: race.slug,
          prevChainSlug: i > 0 ? seasonRaces[i - 1].slug : 'preseason',
          nextChainSlug: i < seasonRaces.length - 1 ? seasonRaces[i + 1].slug : 'postseason',
        },
      });
    }

    // postseason: stats as-of after last race, but participants = last race's entrants
    paths.push({
      params: { season: String(season), chain: 'postseason' },
      props: {
        season,
        raceCount,
        chainSlug: 'postseason',
        raceName: null,
        beforeRaceNumber: lastRn + 1,
        participantRaceNumber: lastRn,
        atDate: lastDate,
        driverLinkRaceSlug: lastRace.slug,
        prevChainSlug: lastRace.slug,
        nextChainSlug: undefined,
      },
    });
  }

  return paths;
}

const {
  season, raceCount, chainSlug, raceName,
  beforeRaceNumber, participantRaceNumber, atDate,
  driverLinkRaceSlug, prevChainSlug, nextChainSlug,
} = Astro.props as {
  season: number;
  raceCount: number;
  chainSlug: string;
  raceName: string | null;
  beforeRaceNumber: number;
  participantRaceNumber: number;
  atDate: string;
  driverLinkRaceSlug: string;
  prevChainSlug: string | undefined;
  nextChainSlug: string | undefined;
};

const pit: PointInTime = chainSlug === 'preseason'
  ? pitForPreseason(season)
  : chainSlug === 'postseason'
    ? pitForPostseason(season)
    : { kind: 'race', season, raceSlug: driverLinkRaceSlug, raceNumber: beforeRaceNumber };

const [drivers, activeGrid] = await Promise.all([
  getAllDriverCareerStatsAsOf(beforeRaceNumber),
  getActiveGridStats({ participantRaceNumber, statsAsOfRaceNumber: beforeRaceNumber, atDate }),
]);

const pageContext: PageContext = {
  kind: 'stats',
  season,
  raceCount,
  chainSlug,
  raceName,
  prevChainSlug,
  nextChainSlug,
};

let title: string;
let description: string;
let canonicalPath: string;
let activeTitle: string;

if (chainSlug === 'preseason') {
  title = `${season} Season — Driver Career Stats (Start of Season)`;
  description = `Career statistics for all F1 drivers going into the ${season} season.`;
  canonicalPath = `/stats/${season}/preseason/`;
  activeTitle = `Active Drivers — Start of ${season} Season`;
} else if (chainSlug === 'postseason') {
  title = `${season} Season — Driver Career Stats (End of Season)`;
  description = `Career statistics for all F1 drivers at the end of the ${season} season.`;
  canonicalPath = `/stats/${season}/postseason/`;
  activeTitle = `Active Drivers — End of ${season} Season`;
} else {
  title = `${raceName} ${season} — Driver Career Stats (Going In)`;
  description = `Career statistics for all F1 drivers going into the ${season} ${raceName}.`;
  canonicalPath = `/stats/${season}/${chainSlug}/`;
  activeTitle = `Active Drivers — ${raceName} ${season}`;
}
---

<Base title={title} description={description} canonical={canonicalPath} {pageContext}>
  <div class="mb-8 border-b border-border pb-6">
    <h1 class="text-3xl font-bold tracking-tight text-fg sm:text-4xl">Driver Career Stats</h1>
    <p class="mt-2 text-lg text-fg-muted">
      {chainSlug === 'preseason'
        ? `Going into ${season} season`
        : chainSlug === 'postseason'
          ? `End of ${season} season`
          : `Going into ${raceName} ${season}`}
    </p>
  </div>

  <StatsDriversView {drivers} {activeGrid} {activeTitle} {pit} />
</Base>
