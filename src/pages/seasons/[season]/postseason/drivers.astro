---
import Base from '../../../../layouts/Base.astro';
import DriverStandingsTable from '../../../../components/standings/DriverStandingsTable.astro';
import { getAllSeasons, getSeasonBookends, getDriverStandings } from '../../../../lib/queries';
import { stripYearPrefix, postseasonLink } from '../../../../lib/format';
import { pitForPostseason } from '../../../../lib/point-in-time';
import type { PageContext } from '../../../../lib/types';

export async function getStaticPaths() {
  return (await getAllSeasons()).map((s) => ({ params: { season: String(s) } }));
}

const { season: seasonStr } = Astro.params;
const season = Number(seasonStr);

const bookends = await getSeasonBookends(season);
const hasData = bookends.latestCompletedRaceNumber != null;
const isComplete = hasData && bookends.latestCompletedRaceNumber === bookends.lastRaceNumber;
const asOfRaceNumber = bookends.latestCompletedRaceNumber ?? bookends.firstRaceNumber;
const lastRaceSlug = stripYearPrefix(bookends.lastSlug, season);
const prevRaceSlug = !isComplete && hasData && bookends.latestCompletedSlug
  ? stripYearPrefix(bookends.latestCompletedSlug, season)
  : lastRaceSlug;
const pit = pitForPostseason(season);

const pageContext: PageContext = {
  kind: 'postseason',
  season,
  raceCount: bookends.raceCount,
  prevRaceSlug,
  inProgressRound: !isComplete && hasData ? bookends.latestCompletedRound : null,
};

const rows = hasData ? await getDriverStandings(asOfRaceNumber) : [];

const title = `${season} Season — Drivers' Championship`;
const description = isComplete
  ? `${season} F1 season final drivers' championship standings.`
  : `${season} F1 season drivers' championship — standings as of round ${bookends.latestCompletedRound}.`;
---

<Base {title} {description} canonical={`${postseasonLink(season)}drivers/`} {pageContext}>
  <DriverStandingsTable
    title={isComplete ? "Drivers' Championship — Final" : "Drivers' Championship — In Progress"}
    {rows}
    {pit}
    emptyNote="No results available yet for this season."
  />
</Base>
