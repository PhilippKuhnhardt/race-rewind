---
import Base from '../../../layouts/Base.astro';
import AllDriversTable from '../../../components/AllDriversTable.astro';
import SeasonGridTable from '../../../components/SeasonGridTable.astro';
import {
  getAllSeasons,
  getSeasonBookends,
  getSeasonGrid,
  getDriverCareerStats,
  getDriverPriorSeasons,
  getDriverBestChampionshipPos,
  getAllDriverCareerStatsAsOf,
} from '../../../lib/queries';
import { stripYearPrefix, preseasonLink } from '../../../lib/format';

export async function getStaticPaths() {
  return (await getAllSeasons()).map((s) => ({
    params: { season: String(s) },
  }));
}

function computeAge(dob: string | null, atDate: string): number | null {
  if (!dob) return null;
  const d = new Date(dob);
  const r = new Date(atDate);
  let age = r.getFullYear() - d.getFullYear();
  const m = r.getMonth() - d.getMonth();
  if (m < 0 || (m === 0 && r.getDate() < d.getDate())) age--;
  return age;
}

const { season: seasonStr } = Astro.params;
const season = Number(seasonStr);

const bookends = await getSeasonBookends(season);
const grid = await getSeasonGrid(bookends.firstRaceNumber);
const allDrivers = await getAllDriverCareerStatsAsOf(bookends.firstRaceNumber);
const firstRaceSlug = stripYearPrefix(bookends.firstSlug, season);

const driverStats = await Promise.all(
  grid.map(async (d) => {
    const [career, seasons, bestChamp] = await Promise.all([
      getDriverCareerStats(d.driver_id, bookends.firstRaceNumber),
      getDriverPriorSeasons(d.driver_id, bookends.firstRaceNumber),
      getDriverBestChampionshipPos(d.driver_id, bookends.firstRaceNumber),
    ]);
    const age = computeAge(d.date_of_birth, bookends.firstDate);
    return { ...d, career, seasons, bestChamp, age };
  })
);

driverStats.sort((a, b) => {
  if (a.team_name !== b.team_name) return (a.team_name ?? '').localeCompare(b.team_name ?? '');
  return b.career.points - a.career.points;
});

const title = `${season} Season — Preseason`;
const description = `${season} F1 season: the starting grid and career statistics for every driver going into the season.`;
---

<Base
  title={title}
  description={description}
  canonical={preseasonLink(season)}
  navSeason={season}
  sidebar={{ season, current: { kind: 'pre' } }}
>
  <div class="page-header">
    <h1>{season} Season</h1>
    <p class="meta">
      {bookends.raceCount} rounds &middot; {bookends.firstDate} &ndash; {bookends.lastDate}
    </p>
  </div>

  <SeasonGridTable
    title="Grid &amp; Statistics Going into the Season"
    drivers={driverStats}
    season={season}
    raceSlug={firstRaceSlug}
  />

  <AllDriversTable drivers={allDrivers} season={season} raceSlug={firstRaceSlug} />
</Base>
