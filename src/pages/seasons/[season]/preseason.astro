---
import Base from '../../../layouts/Base.astro';
import RaceNewsCard from '../../../components/race/RaceNewsCard.astro';
import SeasonGridTable from '../../../components/driver/SeasonGridTable.astro';
import SeasonCalendarTable from '../../../components/race/SeasonCalendarTable.astro';
import {
  getAllSeasons,
  getSeasonBookends,
  getSeasonCalendar,
  getActiveGridStats,
} from '../../../lib/queries';
import { stripYearPrefix, preseasonLink } from '../../../lib/format';
import { pitForPreseason } from '../../../lib/point-in-time';
import { getRaceNews } from '../../../lib/race-news';
import type { PageContext } from '../../../lib/types';

export async function getStaticPaths() {
  return (await getAllSeasons()).map((s) => ({
    params: { season: String(s) },
  }));
}

const { season: seasonStr } = Astro.params;
const season = Number(seasonStr);

const bookends = await getSeasonBookends(season);
const [driverStats, calendar] = await Promise.all([
  getActiveGridStats({
    participantRaceNumber: bookends.firstRaceNumber,
    statsAsOfRaceNumber: bookends.firstRaceNumber,
    atDate: bookends.firstDate,
  }),
  getSeasonCalendar(season),
]);
const firstRaceSlug = stripYearPrefix(bookends.firstSlug, season);
const pit = pitForPreseason(season);

const pageContext: PageContext = {
  kind: 'preseason',
  season,
  raceCount: bookends.raceCount,
  firstRaceSlug,
};

const title = `${season} Season — Start of Season`;
const description = `${season} F1 season: the starting grid and career statistics for every driver going into the season.`;

const newsEntry = await getRaceNews(`${season}-preseason`, 'preseason');
---

<Base
  title={title}
  description={description}
  canonical={preseasonLink(season)}
  {pageContext}
>
  <div class="mb-8 border-b border-border pb-6">
    <h1 class="text-3xl font-bold tracking-tight text-fg sm:text-4xl">{season} Season</h1>
    <p class="mt-2 text-lg text-fg-muted">
      {bookends.raceCount} rounds &middot; {bookends.firstDate} &ndash; {bookends.lastDate}
    </p>
  </div>

  {newsEntry && (
    <div class="mb-8">
      <RaceNewsCard entry={newsEntry} />
    </div>
  )}

  <section class="mb-10">
    <h2 class="mb-3 border-b border-border pb-2 text-lg font-semibold text-fg">Race Calendar</h2>
    <SeasonCalendarTable races={calendar} season={season} />
  </section>

  <SeasonGridTable
    title="Grid &amp; Statistics Going into the Season"
    drivers={driverStats}
    {pit}
  />
</Base>

<script>
  import '../../../scripts/sortable-table.ts';
</script>

<script is:inline define:vars={{ season, kind: 'preseason' }}>
  try { localStorage.setItem('lastRace', JSON.stringify({ kind, season })); } catch { /* ignore */ }
</script>
