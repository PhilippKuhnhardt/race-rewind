---
import RaceSessionLayout from '../../../../layouts/RaceSessionLayout.astro';
import QualifyingTable from '../../../../components/race/QualifyingTable.astro';
import { db } from '../../../../db/client';
import { qualifyingResults, races } from '../../../../db/schema';
import { eq } from 'drizzle-orm';
import { stripYearPrefix, raceLink } from '../../../../lib/format';
import { getQualifyingResults } from '../../../../lib/queries';
import { getRacePageBase } from '../../../../lib/race-page';

export async function getStaticPaths() {
  const rows = await db
    .selectDistinct({ season: races.season, slug: races.slug })
    .from(qualifyingResults)
    .innerJoin(races, eq(races.raceNumber, qualifyingResults.raceNumber));

  return rows.map((r) => ({
    params: { season: String(r.season), race: stripYearPrefix(r.slug, r.season) },
  }));
}

const { season, race: raceSlug } = Astro.params;
const base = await getRacePageBase(season, raceSlug);
if (!base) throw new Error(`Race not found: ${season}-${raceSlug}`);
const { race, raceCount, pageContext, hasQuali, hasSprintQualifying, sessionOrder } = base;

const quali = await getQualifyingResults(race.race_number);

const title = `${race.season} ${race.name} — Qualifying`;
const description = `${race.season} ${race.name} qualifying results at ${race.circuit_name}.`;
---

<RaceSessionLayout {race} {raceCount} {raceSlug} {hasQuali} {hasSprintQualifying} {sessionOrder} {pageContext} {title} {description} canonical={`${raceLink(season, raceSlug)}qualifying/`} activeId="qualifying">
  <section>
    <h2 class="mb-4 text-lg font-semibold text-fg">Qualifying</h2>
    <QualifyingTable {quali} season={race.season} {raceSlug} />
  </section>
</RaceSessionLayout>
