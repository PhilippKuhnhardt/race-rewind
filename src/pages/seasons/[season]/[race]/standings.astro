---
import Base from '../../../../layouts/Base.astro';
import RaceHeroCard from '../../../../components/race/RaceHeroCard.astro';
import RaceSubNav from '../../../../components/race/RaceSubNav.astro';
import DriverStandingsTable from '../../../../components/standings/DriverStandingsTable.astro';
import TeamStandingsTable from '../../../../components/standings/TeamStandingsTable.astro';
import {
  getAllRaces,
  getDriverStandings,
  getTeamStandings,
  getDriverStandingsBeforeRace,
  getTeamStandingsBeforeRace,
} from '../../../../lib/queries';
import { getRacePageBase } from '../../../../lib/race-page';
import { raceLink } from '../../../../lib/format';

export async function getStaticPaths() {
  return (await getAllRaces()).map((r) => ({
    params: { season: String(r.season), race: r.race_slug },
  }));
}

const { season, race: raceSlug } = Astro.params;
const base = await getRacePageBase(season, raceSlug);
if (!base) throw new Error(`Race not found: ${season}-${raceSlug}`);
const { race, raceCount, pageContext } = base;

const [driverChamp, teamChamp, preRaceDriverChamp, preRaceTeamChamp] = await Promise.all([
  getDriverStandings(race.race_number),
  getTeamStandings(race.race_number),
  getDriverStandingsBeforeRace(race.race_number),
  getTeamStandingsBeforeRace(race.race_number),
]);

const preRaceDriverPosById = new Map(preRaceDriverChamp.map((r) => [r.driver_id, r.position]));
const preRaceTeamPosById = new Map(preRaceTeamChamp.map((r) => [r.team_id, r.position]));

const title = `${race.season} ${race.name} — Standings`;
const description = `Drivers' and constructors' championship standings after the ${race.season} ${race.name}.`;
---

<Base title={title} description={description} canonical={`${raceLink(season, raceSlug)}standings/`} {pageContext}>
  <RaceHeroCard
    name={race.name}
    season={race.season}
    round={race.round}
    raceCount={raceCount}
    date={race.date}
    circuitName={race.circuit_name}
    circuitLocality={race.circuit_locality}
    circuitCountry={race.circuit_country}
  />

  <RaceSubNav
    season={race.season}
    raceSlug={raceSlug}
    hasQuali={race.season >= 1994}
    hasSprint={!!race.has_sprint}
    activeId="standings"
  />

  <DriverStandingsTable
    title="Drivers' Championship — After This Race"
    rows={driverChamp}
    season={race.season}
    raceSlug={raceSlug}
    prevPositions={preRaceDriverPosById}
    emptyNote="First race of the season — championship not yet started."
  />

  {preRaceDriverChamp.length > 0 && (
    <DriverStandingsTable
      title="Drivers' Championship — Going Into This Race"
      rows={preRaceDriverChamp}
      season={race.season}
      raceSlug={raceSlug}
    />
  )}

  <TeamStandingsTable
    title="Constructors' Championship — After This Race"
    rows={teamChamp}
    season={race.season}
    raceSlug={raceSlug}
    prevPositions={preRaceTeamPosById}
  />
</Base>
