---
import RaceSessionLayout from '../../../../layouts/RaceSessionLayout.astro';
import DriverStandingsTable from '../../../../components/standings/DriverStandingsTable.astro';
import TeamStandingsTable from '../../../../components/standings/TeamStandingsTable.astro';
import PreRaceLeaders from '../../../../components/race/PreRaceLeaders.astro';
import { getAllRaces, getDriverStandingsBeforeRace, getTeamStandingsBeforeRace } from '../../../../lib/queries';
import { getRacePageBase } from '../../../../lib/race-page';
import { raceLink } from '../../../../lib/format';

export async function getStaticPaths() {
  return (await getAllRaces()).map((r) => ({
    params: { season: String(r.season), race: r.race_slug },
  }));
}

const { season, race: raceSlug } = Astro.params;
const base = await getRacePageBase(season, raceSlug);
if (!base) throw new Error(`Race not found: ${season}-${raceSlug}`);
const { race, raceCount, pageContext, hasQuali } = base;

const [preRaceDriverChamp, preRaceTeamChamp] = await Promise.all([
  getDriverStandingsBeforeRace(race.race_number),
  getTeamStandingsBeforeRace(race.race_number),
]);

const driverLeader = preRaceDriverChamp[0]
  ? {
      full_name: preRaceDriverChamp[0].full_name,
      driver_slug: preRaceDriverChamp[0].driver_slug,
      points: preRaceDriverChamp[0].points,
      gap: preRaceDriverChamp[0].points - (preRaceDriverChamp[1]?.points ?? preRaceDriverChamp[0].points),
    }
  : null;

const teamLeader = preRaceTeamChamp[0]
  ? {
      team_name: preRaceTeamChamp[0].team_name,
      team_slug: preRaceTeamChamp[0].team_slug,
      points: preRaceTeamChamp[0].points,
      gap: preRaceTeamChamp[0].points - (preRaceTeamChamp[1]?.points ?? preRaceTeamChamp[0].points),
    }
  : null;

const title = `${race.season} ${race.name}`;
const description = `${race.season} ${race.name} at ${race.circuit_name}${race.circuit_locality ? ', ' + race.circuit_locality : ''}: standings and session details.`;
---

<RaceSessionLayout {race} {raceCount} {raceSlug} {hasQuali} {pageContext} {title} {description} canonical={raceLink(season, raceSlug)} activeId="overview">

  <div class="space-y-8">
    <PreRaceLeaders {driverLeader} {teamLeader} season={race.season} {raceSlug} />

    <!-- Pre-race standings truncated — link to full Drivers/Teams tabs -->
    <DriverStandingsTable
      title="Drivers' Championship — Going Into This Race"
      rows={preRaceDriverChamp.slice(0, 10)}
      season={race.season}
      raceSlug={raceSlug}
      emptyNote="First race of the season — championship not yet started."
      viewAllHref={`/seasons/${race.season}/${raceSlug}/drivers/`}
    />

    <TeamStandingsTable
      title="Constructors' Championship — Going Into This Race"
      rows={preRaceTeamChamp.slice(0, 5)}
      season={race.season}
      raceSlug={raceSlug}
      viewAllHref={`/seasons/${race.season}/${raceSlug}/teams/`}
      emptyNote="First race of the season — championship not yet started."
    />

    <!-- Session link cards -->
    <section>
      <h2 class="mb-4 text-lg font-semibold text-fg">Sessions</h2>
      <div class="grid grid-cols-2 gap-3 sm:grid-cols-3">
        {hasQuali && (
          <a href={`/seasons/${race.season}/${raceSlug}/qualifying/`} class="group flex flex-col rounded-xl border border-border bg-bg-alt p-4 no-underline transition-all hover:border-accent hover:bg-bg-hover">
            <span class="text-sm font-semibold text-fg group-hover:text-accent transition-colors">Qualifying</span>
            <span class="mt-0.5 text-xs text-fg-muted">Grid order</span>
          </a>
        )}
        {!hasQuali && (
          <a href={`/seasons/${race.season}/${raceSlug}/grid/`} class="group flex flex-col rounded-xl border border-border bg-bg-alt p-4 no-underline transition-all hover:border-accent hover:bg-bg-hover">
            <span class="text-sm font-semibold text-fg group-hover:text-accent transition-colors">Starting Grid</span>
            <span class="mt-0.5 text-xs text-fg-muted">Grid order</span>
          </a>
        )}
        {(!!race.has_sprint) && (
          <>
            <a href={`/seasons/${race.season}/${raceSlug}/sprint-qualifying/`} class="group flex flex-col rounded-xl border border-border bg-bg-alt p-4 no-underline transition-all hover:border-accent hover:bg-bg-hover">
              <span class="text-sm font-semibold text-fg group-hover:text-accent transition-colors">Sprint Qualifying</span>
              <span class="mt-0.5 text-xs text-fg-muted">Sprint grid</span>
            </a>
            <a href={`/seasons/${race.season}/${raceSlug}/sprint/`} class="group flex flex-col rounded-xl border border-border bg-bg-alt p-4 no-underline transition-all hover:border-accent hover:bg-bg-hover">
              <span class="text-sm font-semibold text-fg group-hover:text-accent transition-colors">Sprint</span>
              <span class="mt-0.5 text-xs text-fg-muted">Sprint race results</span>
            </a>
          </>
        )}
        <a href={`/seasons/${race.season}/${raceSlug}/race/`} class="group flex flex-col rounded-xl border border-border bg-bg-alt p-4 no-underline transition-all hover:border-accent hover:bg-bg-hover">
          <span class="text-sm font-semibold text-fg group-hover:text-accent transition-colors">Race</span>
          <span class="mt-0.5 text-xs text-fg-muted">Results &amp; podium</span>
        </a>
      </div>
    </section>
  </div>

</RaceSessionLayout>
