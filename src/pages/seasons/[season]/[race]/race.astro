---
import RaceSessionLayout from '../../../../layouts/RaceSessionLayout.astro';
import RaceResultsTable from '../../../../components/race/RaceResultsTable.astro';
import Podium from '../../../../components/race/Podium.astro';
import { getAllRaces, getRaceResults } from '../../../../lib/queries';
import { getRacePageBase } from '../../../../lib/race-page';
import { raceLink } from '../../../../lib/format';
import { raceSessionSeo } from '../../../../lib/seo';

export async function getStaticPaths() {
  return (await getAllRaces()).map((r) => ({
    params: { season: String(r.season), race: r.race_slug },
  }));
}

const { season, race: raceSlug } = Astro.params;
const base = await getRacePageBase(season, raceSlug);
if (!base) throw new Error(`Race not found: ${season}-${raceSlug}`);
const { race, raceCount, pageContext, hasQuali, hasSprintQualifying, sessionOrder } = base;

const results = await getRaceResults(race.race_number);

const podium = results
  .filter((r) => r.position != null && r.position <= 3)
  .sort((a, b) => (a.position ?? 99) - (b.position ?? 99));

const { title, description } = raceSessionSeo(race, 'Race Results');
---

<RaceSessionLayout {race} {raceCount} {raceSlug} {hasQuali} {hasSprintQualifying} {sessionOrder} {pageContext} {title} {description} canonical={`${raceLink(season, raceSlug)}race/`} activeId="race">
  <div class="space-y-8">

    <Podium {podium} season={race.season} {raceSlug} />

    <section>
      <h2 class="mb-4 text-lg font-semibold text-fg">Race</h2>
      <RaceResultsTable {results} season={race.season} {raceSlug} />
    </section>

  </div>
</RaceSessionLayout>
