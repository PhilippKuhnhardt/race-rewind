---
import RaceHeroCard from '../../../../components/race/RaceHeroCard.astro';
import TeamStandingsTable from '../../../../components/standings/TeamStandingsTable.astro';
import Base from '../../../../layouts/Base.astro';
import { raceLink } from '../../../../lib/format';
import { pitForRace } from '../../../../lib/point-in-time';
import { getAllRaces, getTeamStandingsBeforeRace } from '../../../../lib/queries';
import { getRacePageBase } from '../../../../lib/race-page';

export async function getStaticPaths() {
  return (await getAllRaces()).map((r) => ({
    params: { season: String(r.season), race: r.race_slug },
  }));
}

const { season, race: raceSlug } = Astro.params;
const base = await getRacePageBase(season, raceSlug);
if (!base) throw new Error(`Race not found: ${season}-${raceSlug}`);
const { race, raceCount, pageContext } = base;
const pit = pitForRace(race, raceSlug!);

const preRaceTeamChamp = await getTeamStandingsBeforeRace(race.race_number);

const title = `${race.season} ${race.name} — Teams`;
const description = `Constructor championship standings going into the ${race.season} ${race.name}.`;
---

<Base
  title={title}
  description={description}
  canonical={`${raceLink(season, raceSlug)}teams/`}
  {pageContext}
>
  <RaceHeroCard
    name={race.name}
    season={race.season}
    round={race.round}
    raceCount={raceCount}
    date={race.date}
    circuitName={race.circuit_name}
    circuitLocality={race.circuit_locality}
    circuitCountry={race.circuit_country}
  />

  <TeamStandingsTable
    title="Constructors' Championship"
    rows={preRaceTeamChamp}
    {pit}
    emptyNote="First race of the season — championship not yet started."
  />
</Base>
