---
import Base from '../../../../layouts/Base.astro';
import RaceHeroCard from '../../../../components/race/RaceHeroCard.astro';
import DriverStandingsTable from '../../../../components/standings/DriverStandingsTable.astro';
import { getAllRaces, getDriverStandingsBeforeRace } from '../../../../lib/queries';
import { getRacePageBase } from '../../../../lib/race-page';
import { raceLink } from '../../../../lib/format';

export async function getStaticPaths() {
  return (await getAllRaces()).map((r) => ({
    params: { season: String(r.season), race: r.race_slug },
  }));
}

const { season, race: raceSlug } = Astro.params;
const base = await getRacePageBase(season, raceSlug);
if (!base) throw new Error(`Race not found: ${season}-${raceSlug}`);
const { race, raceCount, pageContext } = base;

const preRaceDriverChamp = await getDriverStandingsBeforeRace(race.race_number);

const title = `${race.season} ${race.name} — Drivers`;
const description = `Driver championship standings going into the ${race.season} ${race.name}.`;
---

<Base title={title} description={description} canonical={`${raceLink(season, raceSlug)}drivers/`} {pageContext}>
  <RaceHeroCard
    name={race.name}
    season={race.season}
    round={race.round}
    raceCount={raceCount}
    date={race.date}
    circuitName={race.circuit_name}
    circuitLocality={race.circuit_locality}
    circuitCountry={race.circuit_country}
  />

  <DriverStandingsTable
    title="Drivers' Championship — Going Into This Race"
    rows={preRaceDriverChamp}
    season={race.season}
    raceSlug={raceSlug}
    emptyNote="First race of the season — championship not yet started."
  />
</Base>
