---
import RaceSessionLayout from '../../../../layouts/RaceSessionLayout.astro';
import RaceResultsTable from '../../../../components/race/RaceResultsTable.astro';
import { db } from '../../../../db/client';
import { races } from '../../../../db/schema';
import { eq } from 'drizzle-orm';
import { stripYearPrefix, raceLink } from '../../../../lib/format';
import { getSprintResults } from '../../../../lib/queries';
import { getRacePageBase } from '../../../../lib/race-page';
import { raceSessionSeo } from '../../../../lib/seo';

export async function getStaticPaths() {
  const rows = await db
    .select({ season: races.season, slug: races.slug })
    .from(races)
    .where(eq(races.hasSprint, 1));

  return rows.map((r) => ({
    params: { season: String(r.season), race: stripYearPrefix(r.slug, r.season) },
  }));
}

const { season, race: raceSlug } = Astro.params;
const base = await getRacePageBase(season, raceSlug);
if (!base) throw new Error(`Race not found: ${season}-${raceSlug}`);
const { race, raceCount, pageContext, hasQuali, hasSprintQualifying, sessionOrder } = base;

const sprint = await getSprintResults(race.race_number);

const { title, description } = raceSessionSeo(race, 'Sprint');
---

<RaceSessionLayout {race} {raceCount} {raceSlug} {hasQuali} {hasSprintQualifying} {sessionOrder} {pageContext} {title} {description} canonical={`${raceLink(season, raceSlug)}sprint/`} activeId="sprint">
  <section>
    <h2 class="mb-4 text-lg font-semibold text-fg">Sprint Race</h2>
    <RaceResultsTable results={sprint} season={race.season} {raceSlug} isSprint={true} />
  </section>
</RaceSessionLayout>
