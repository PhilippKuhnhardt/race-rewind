---
import Base from '../../../layouts/Base.astro';
import DriverStandingsTable from '../../../components/DriverStandingsTable.astro';
import TeamStandingsTable from '../../../components/TeamStandingsTable.astro';
import {
  getAllRaces,
  getRaceBySlug,
  getQualifyingResults,
  getSprintQualifyingResults,
  getSprintResults,
  getRaceResults,
  getDriverStandings,
  getTeamStandings,
  getDriverStandingsBeforeRace,
  getTeamStandingsBeforeRace,
  getSeasonBookends,
} from '../../../lib/queries';
import { orDash, formatPts, formatPos, formatGap } from '../../../lib/format';

export async function getStaticPaths() {
  return (await getAllRaces()).map((r) => ({
    params: { season: String(r.season), race: r.race_slug },
  }));
}

const { season, race: raceSlug } = Astro.params;
const fullSlug = `${season}-${raceSlug}`;
const race = await getRaceBySlug(fullSlug);
if (!race) throw new Error(`Race not found: ${fullSlug}`);

const { raceCount } = await getSeasonBookends(race.season);

const [quali, sprintQuali, sprint, results, driverChamp, teamChamp, preRaceDriverChamp, preRaceTeamChamp] =
  await Promise.all([
    getQualifyingResults(race.race_number),
    race.has_sprint ? getSprintQualifyingResults(race.race_number) : Promise.resolve([]),
    race.has_sprint ? getSprintResults(race.race_number) : Promise.resolve([]),
    getRaceResults(race.race_number),
    getDriverStandings(race.race_number),
    getTeamStandings(race.race_number),
    getDriverStandingsBeforeRace(race.race_number),
    getTeamStandingsBeforeRace(race.race_number),
  ]);

const preRaceDriverPosById = new Map(preRaceDriverChamp.map((r) => [r.driver_id, r.position]));
const preRaceTeamPosById = new Map(preRaceTeamChamp.map((r) => [r.team_id, r.position]));

const isModernQuali = quali.length > 0 && (quali[0].q1_time != null || quali[0].q2_time != null);
const winnerTime = results.find((r) => r.position === 1)?.time ?? null;
// Starting grid derived from race results — shown only when no qualifying data exists
const startingGrid =
  quali.length === 0
    ? [...results]
        .filter((r) => r.grid != null && r.grid > 0)
        .sort((a, b) => a.grid! - b.grid!)
    : [];

const title = `${race.season} ${race.name} — Results & Standings`;
const description = `${race.season} ${race.name} at ${race.circuit_name}${race.circuit_locality ? ', ' + race.circuit_locality : ''}: ${race.has_sprint ? 'sprint, ' : ''}race results and championship standings.`;

const driverLink = (driverSlug: string) =>
  `/drivers/${driverSlug}/${race.season}/${raceSlug}/`;
---

<Base
  title={title}
  description={description}
  canonical={`/seasons/${season}/${raceSlug}/`}
  navSeason={race.season}
  sidebar={{ season: race.season, current: { kind: 'race', raceSlug } }}
>
  <div class="page-header">
    <h1>{race.season} {race.name}</h1>
    <p class="meta">
      {race.circuit_name}{race.circuit_locality ? `, ${race.circuit_locality}` : ''} &mdash; {
        race.date
      }
      &nbsp;&middot;&nbsp; Round {race.round} of {raceCount}
    </p>
  </div>

  <!-- CSS-only tabs: Pre-Race (default) and Post-Race -->
  <div class="race-tabs">
    <input type="radio" id="tab-pre" name="race-tab" checked />
    <input type="radio" id="tab-post" name="race-tab" />
    <div class="tab-bar">
      <label for="tab-pre">Pre-Race</label>
      <label for="tab-post">Post-Race</label>
    </div>

    <!-- PRE-RACE PANEL -->
    <div class="tab-panel tab-pre-panel">
      <!-- Qualifying (when data exists) -->
      {
        quali.length > 0 && (
          <section class="section">
            <h2>Qualifying</h2>
            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    <th class="num">Pos</th>
                    <th>Driver</th>
                    <th>Team</th>
                    {isModernQuali ? (
                      <>
                        <th class="time">Q1</th>
                        <th class="time">Q2</th>
                        <th class="time">Q3</th>
                      </>
                    ) : (
                      <th class="time">Time</th>
                    )}
                  </tr>
                </thead>
                <tbody>
                  {quali.map((row) => (
                    <tr>
                      <td class="num pos">{row.position ?? '—'}</td>
                      <td>
                        <a href={driverLink(row.driver_slug)}>{row.full_name}</a>
                      </td>
                      <td>{row.team_name}</td>
                      {isModernQuali ? (
                        <>
                          <td class="time">{orDash(row.q1_time)}</td>
                          <td class="time">{orDash(row.q2_time)}</td>
                          <td class="time">{orDash(row.q3_time)}</td>
                        </>
                      ) : (
                        <td class="time">{orDash(row.qualifying_time)}</td>
                      )}
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </section>
        )
      }

      <!-- Starting grid fallback for races without qualifying data -->
      {
        startingGrid.length > 0 && (
          <section class="section">
            <h2>Starting Grid</h2>
            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    <th class="num">Grid</th>
                    <th>Driver</th>
                    <th>Team</th>
                    <th class="num">No.</th>
                  </tr>
                </thead>
                <tbody>
                  {startingGrid.map((row) => (
                    <tr>
                      <td class="num pos">{row.grid}</td>
                      <td>
                        <a href={driverLink(row.driver_slug)}>{row.full_name}</a>
                      </td>
                      <td>{row.team_name}</td>
                      <td class="num">{row.car_number ?? '—'}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </section>
        )
      }

      <!-- Sprint Qualifying -->
      {
        sprintQuali.length > 0 && (
          <section class="section">
            <h2>Sprint Qualifying</h2>
            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    <th class="num">Pos</th>
                    <th>Driver</th>
                    <th>Team</th>
                    <th class="time">SQ1</th>
                    <th class="time">SQ2</th>
                    <th class="time">SQ3</th>
                    <th>Out</th>
                  </tr>
                </thead>
                <tbody>
                  {sprintQuali.map((row) => (
                    <tr>
                      <td class="num pos">{row.position ?? '—'}</td>
                      <td>
                        <a href={driverLink(row.driver_slug)}>{row.full_name}</a>
                      </td>
                      <td>{row.team_name}</td>
                      <td class="time">{orDash(row.sq1_time)}</td>
                      <td class="time">{orDash(row.sq2_time)}</td>
                      <td class="time">{orDash(row.sq3_time)}</td>
                      <td>{row.knocked_out_in ?? '—'}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </section>
        )
      }

      <!-- Pre-race championship standings -->
      <DriverStandingsTable
        title="Championship Going In"
        rows={preRaceDriverChamp}
        season={race.season}
        raceSlug={raceSlug}
        emptyNote="First race of the season — championship not yet started."
      />
    </div>

    <!-- POST-RACE PANEL -->
    <div class="tab-panel tab-post-panel">
      <!-- Sprint Race -->
      {
        sprint.length > 0 && (
          <section class="section">
            <h2>Sprint Race</h2>
            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    <th class="num">Pos</th>
                    <th>Driver</th>
                    <th>Team</th>
                    <th class="num">Grid</th>
                    <th class="num">Laps</th>
                    <th class="time">Time / Gap</th>
                    <th>Status</th>
                    <th class="num">Pts</th>
                  </tr>
                </thead>
                <tbody>
                  {sprint.map((row) => (
                    <tr>
                      <td class="num pos">{formatPos(row.position)}</td>
                      <td class:list={[{ fl: row.fastest_lap_rank === 1 }]}>
                        <a href={driverLink(row.driver_slug)}>{row.full_name}</a>
                      </td>
                      <td>{row.team_name}</td>
                      <td class="num">{row.grid ? row.grid : '—'}</td>
                      <td class="num">{row.laps_completed ?? '—'}</td>
                      <td class="time">{orDash(row.time)}</td>
                      <td class:list={[{ dnf: row.position == null }]}>{row.detail ?? '—'}</td>
                      <td class="num">{formatPts(row.points)}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </section>
        )
      }

      <!-- Race -->
      {
        results.length > 0 && (
          <section class="section">
            <h2>Race</h2>
            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    <th class="num">Pos</th>
                    <th>Driver</th>
                    <th>Team</th>
                    <th class="num">No.</th>
                    <th class="num">Grid</th>
                    <th class="num">Laps</th>
                    <th class="time">Time / Gap</th>
                    <th>Status</th>
                    <th class="num">Stops</th>
                    <th class="num">Pts</th>
                  </tr>
                </thead>
                <tbody>
                  {results.map((row) => {
                    const gap = formatGap(winnerTime, row);
                    const status = row.is_classified ? 'Finished' : (row.detail ?? '—');
                    return (
                      <tr>
                        <td class="num pos">{formatPos(row.position)}</td>
                        <td class:list={[{ fl: row.fastest_lap_rank === 1 }]}>
                          <a href={driverLink(row.driver_slug)}>{row.full_name}</a>
                        </td>
                        <td>{row.team_name}</td>
                        <td class="num">{row.car_number ?? '—'}</td>
                        <td class="num">{row.grid ? row.grid : '—'}</td>
                        <td class="num">{row.laps_completed ?? '—'}</td>
                        <td class="time">{gap}</td>
                        <td class:list={[{ dnf: !row.is_classified }]}>{status}</td>
                        <td class="num">{row.pit_stop_count ?? '—'}</td>
                        <td class="num">{formatPts(row.points)}</td>
                      </tr>
                    );
                  })}
                </tbody>
              </table>
            </div>
            <p class="section-note">Purple driver name = set fastest lap of the race.</p>
          </section>
        )
      }

      <!-- Drivers' Championship (post-race with position deltas) -->
      <DriverStandingsTable
        title="Drivers' Championship"
        rows={driverChamp}
        season={race.season}
        raceSlug={raceSlug}
        prevPositions={preRaceDriverPosById}
      />

      <!-- Constructors' Championship -->
      <TeamStandingsTable
        title="Constructors' Championship"
        rows={teamChamp}
        prevPositions={preRaceTeamPosById}
      />
    </div>
  </div>
</Base>
