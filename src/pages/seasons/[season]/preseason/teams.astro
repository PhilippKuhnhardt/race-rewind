---
import Base from '../../../../layouts/Base.astro';
import TeamStandingsTable from '../../../../components/standings/TeamStandingsTable.astro';
import { getAllSeasons, getSeasonBookends } from '../../../../lib/queries';
import { stripYearPrefix, preseasonLink } from '../../../../lib/format';
import { getTeamStandingsBeforeRace } from '../../../../lib/queries';
import { pitForPreseason } from '../../../../lib/point-in-time';
import type { PageContext } from '../../../../lib/types';

export async function getStaticPaths() {
  return (await getAllSeasons()).map((s) => ({ params: { season: String(s) } }));
}

const { season: seasonStr } = Astro.params;
const season = Number(seasonStr);

const bookends = await getSeasonBookends(season);
const firstRaceSlug = stripYearPrefix(bookends.firstSlug, season);
const pit = pitForPreseason(season);

const pageContext: PageContext = {
  kind: 'preseason',
  season,
  raceCount: bookends.raceCount,
  firstRaceSlug,
};

const rows = await getTeamStandingsBeforeRace(bookends.firstRaceNumber);

const title = `${season} Season — Teams (Preseason)`;
const description = `Constructor championship standings going into the ${season} season.`;
---

<Base {title} {description} canonical={`${preseasonLink(season)}teams/`} {pageContext}>
  <TeamStandingsTable
    title="Constructors' Championship — Going Into the Season"
    {rows}
    {pit}
    emptyNote="No championship data before the season starts."
  />
</Base>
