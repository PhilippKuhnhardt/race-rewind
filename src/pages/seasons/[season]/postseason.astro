---
import Base from '../../../layouts/Base.astro';
import AllDriversTable from '../../../components/AllDriversTable.astro';
import SeasonGridTable from '../../../components/SeasonGridTable.astro';
import DriverStandingsTable from '../../../components/DriverStandingsTable.astro';
import TeamStandingsTable from '../../../components/TeamStandingsTable.astro';
import {
  getAllSeasons,
  getSeasonBookends,
  getSeasonGrid,
  getDriverStandings,
  getTeamStandings,
  getDriverCareerStats,
  getDriverPriorSeasons,
  getDriverBestChampionshipPos,
  getAllDriverCareerStatsAsOf,
} from '../../../lib/queries';
import { stripYearPrefix, postseasonLink } from '../../../lib/format';

export async function getStaticPaths() {
  return (await getAllSeasons()).map((s) => ({
    params: { season: String(s) },
  }));
}

function computeAge(dob: string | null, atDate: string): number | null {
  if (!dob) return null;
  const d = new Date(dob);
  const r = new Date(atDate);
  let age = r.getFullYear() - d.getFullYear();
  const m = r.getMonth() - d.getMonth();
  if (m < 0 || (m === 0 && r.getDate() < d.getDate())) age--;
  return age;
}

const { season: seasonStr } = Astro.params;
const season = Number(seasonStr);

const bookends = await getSeasonBookends(season);

const hasData = bookends.latestCompletedRaceNumber != null;
const isComplete =
  hasData && bookends.latestCompletedRaceNumber === bookends.lastRaceNumber;

// asOfRaceNumber is the latest race with results, or the first race if none yet.
const asOfRaceNumber = bookends.latestCompletedRaceNumber ?? bookends.firstRaceNumber;
const asOfDate = bookends.latestCompletedDate ?? bookends.firstDate;

const [driverChamp, teamChamp, grid] = await Promise.all([
  hasData ? getDriverStandings(asOfRaceNumber) : Promise.resolve([]),
  hasData ? getTeamStandings(asOfRaceNumber) : Promise.resolve([]),
  getSeasonGrid(asOfRaceNumber),
]);
const lastRaceSlug = stripYearPrefix(bookends.lastSlug, season);

// Career totals including the as-of race: pass asOfRaceNumber + 1 (strict-less-than logic)
const careerRefRaceNumber = hasData ? asOfRaceNumber + 1 : bookends.firstRaceNumber;

const [driverCareerRows, allDrivers] = await Promise.all([
  Promise.all(
    grid.map(async (d) => {
      const [career, seasons, bestChamp] = await Promise.all([
        getDriverCareerStats(d.driver_id, careerRefRaceNumber),
        getDriverPriorSeasons(d.driver_id, careerRefRaceNumber),
        getDriverBestChampionshipPos(d.driver_id, careerRefRaceNumber),
      ]);
      const age = computeAge(d.date_of_birth, asOfDate);
      return { ...d, career, seasons, bestChamp, age };
    })
  ),
  getAllDriverCareerStatsAsOf(careerRefRaceNumber),
]);

driverCareerRows.sort((a, b) => {
  if (a.team_name !== b.team_name) return (a.team_name ?? '').localeCompare(b.team_name ?? '');
  return b.career.points - a.career.points;
});

const title = `${season} Season — Postseason`;
const description = isComplete
  ? `${season} F1 season final standings: drivers' and constructors' championships and career totals.`
  : `${season} F1 season in progress — standings as of round ${bookends.latestCompletedRound}.`;
---

<Base
  title={title}
  description={description}
  canonical={postseasonLink(season)}
  navSeason={season}
  sidebar={{ season, current: { kind: 'post' } }}
>
  <div class="page-header">
    <h1>{season} Season</h1>
    <p class="meta">
      {bookends.raceCount} rounds &middot; {bookends.firstDate} &ndash; {bookends.lastDate}
    </p>
  </div>

  {
    !isComplete && hasData && (
      <div class="season-in-progress">
        Season in progress &mdash; standings as of round {bookends.latestCompletedRound} / {bookends.raceCount}
        ({bookends.latestCompletedName}).
      </div>
    )
  }
  {
    !hasData && (
      <div class="season-in-progress">No results available yet for this season.</div>
    )
  }

  <DriverStandingsTable
    title="Drivers' Championship"
    rows={driverChamp}
    season={season}
    raceSlug={lastRaceSlug}
  />

  <TeamStandingsTable title="Constructors' Championship" rows={teamChamp} season={season} raceSlug={lastRaceSlug} />

  <SeasonGridTable
    title="Career Totals After the Season"
    drivers={driverCareerRows}
    season={season}
    raceSlug={lastRaceSlug}
  />

  <AllDriversTable drivers={allDrivers} season={season} raceSlug={lastRaceSlug} />
</Base>
