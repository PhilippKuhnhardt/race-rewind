---
import Base from '../../../layouts/Base.astro';
import DriverStandingsTable from '../../../components/standings/DriverStandingsTable.astro';
import TeamStandingsTable from '../../../components/standings/TeamStandingsTable.astro';
import {
  getAllSeasons,
  getSeasonBookends,
  getDriverStandings,
  getTeamStandings,
} from '../../../lib/queries';
import { stripYearPrefix, postseasonLink } from '../../../lib/format';
import type { PageContext } from '../../../lib/types';

export async function getStaticPaths() {
  return (await getAllSeasons()).map((s) => ({
    params: { season: String(s) },
  }));
}

const { season: seasonStr } = Astro.params;
const season = Number(seasonStr);

const bookends = await getSeasonBookends(season);

const hasData = bookends.latestCompletedRaceNumber != null;
const isComplete =
  hasData && bookends.latestCompletedRaceNumber === bookends.lastRaceNumber;

const asOfRaceNumber = bookends.latestCompletedRaceNumber ?? bookends.firstRaceNumber;

const lastRaceSlug = stripYearPrefix(bookends.lastSlug, season);
const prevRaceSlug = !isComplete && hasData && bookends.latestCompletedSlug
  ? stripYearPrefix(bookends.latestCompletedSlug, season)
  : lastRaceSlug;

const pageContext: PageContext = {
  kind: 'postseason',
  season,
  raceCount: bookends.raceCount,
  prevRaceSlug,
  inProgressRound: !isComplete && hasData ? bookends.latestCompletedRound : null,
};

const [driverChamp, teamChamp] = await Promise.all([
  hasData ? getDriverStandings(asOfRaceNumber) : Promise.resolve([]),
  hasData ? getTeamStandings(asOfRaceNumber) : Promise.resolve([]),
]);

const title = `${season} Season — End of Season`;
const description = isComplete
  ? `${season} F1 season final standings: drivers' and constructors' championships.`
  : `${season} F1 season in progress — standings as of round ${bookends.latestCompletedRound}.`;
---

<Base
  title={title}
  description={description}
  canonical={postseasonLink(season)}
  {pageContext}
>
  <div class="mb-8 border-b border-border pb-6">
    <h1 class="text-3xl font-bold tracking-tight text-fg sm:text-4xl">{season} Season</h1>
    <p class="mt-2 text-fg-muted">
      {bookends.raceCount} rounds &middot; {bookends.firstDate} &ndash; {bookends.lastDate}
    </p>
  </div>

  {!isComplete && hasData && (
    <div class="mb-6 rounded-lg border border-border bg-bg-alt px-4 py-3 text-sm text-fg-muted">
      Season in progress — standings as of round {bookends.latestCompletedRound} / {bookends.raceCount}
      ({bookends.latestCompletedName}).
    </div>
  )}
  {!hasData && (
    <div class="mb-6 rounded-lg border border-border bg-bg-alt px-4 py-3 text-sm text-fg-muted">
      No results available yet for this season.
    </div>
  )}

  <DriverStandingsTable
    title="Drivers' Championship"
    rows={driverChamp}
    season={season}
    raceSlug={lastRaceSlug}
  />

  <TeamStandingsTable title="Constructors' Championship" rows={teamChamp} season={season} raceSlug={lastRaceSlug} />
</Base>


<script>
  import '../../../scripts/sortable-table.ts';
</script>