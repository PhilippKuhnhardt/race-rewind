---
import Base from '../../layouts/Base.astro';
---

<Base
  title="Impressum - Race Rewind"
  description="Impressum von Race Rewind."
  canonical="/legal/impressum/"
  robots="noindex"
  lang="de"
>
  <article class="mx-auto max-w-2xl">
    <header class="mb-8">
      <p class="text-sm font-semibold uppercase tracking-wider text-accent">Rechtliches</p>
      <h1 class="mt-2 text-3xl font-extrabold tracking-tight text-fg sm:text-4xl">Impressum</h1>
    </header>

    <section class="space-y-3 text-base leading-7 text-fg">
      <h2 class="text-xl font-bold tracking-tight text-fg">Anbieter</h2>
      <p>
        Philipp Kuhnhardt<br />
        Bebelstr. 52<br />
        70193 Stuttgart
      </p>
    </section>

    <section class="mt-8 space-y-3 text-base leading-7 text-fg">
      <h2 class="text-xl font-bold tracking-tight text-fg">Kontakt</h2>
      <p>
        E-Mail: racerewind@posteo.de<br />
        Alternativ per Kontakformular auf der <a
          href="/contact/"
          class="font-medium text-accent underline-offset-4 hover:underline">Kontaktseite</a
        >
      </p>
    </section>
  </article>
</Base>
