---
import ContinueButton from '../components/ContinueButton.svelte';
import Base from '../layouts/Base.astro';
import { getAllSeasons } from '../lib/queries';

const seasons = await getAllSeasons();

const featuredMoments = [
  {
    label: 'Suzuka, 1988',
    title: 'Can Senna end it here?',
    description:
      'Understand the championship implications of the legendary Japanese Grand Prix, with McLaren teammates fighting over a title.',
    href: '/seasons/1988/japanese-grand-prix/',
  },
  {
    label: 'Preseason, 2012',
    title: 'The title-heavy grid',
    description:
      'Experience one of the most exciting seasons with six World Champions on the grid, fourteen titles between them, and Alonso and Vettel chasing a third crown.',
    href: '/seasons/2012/preseason/',
  },
  {
    label: 'Abu Dhabi, 2021',
    title: 'Level into the finale',
    description:
      'Step into the final round with Verstappen and Hamilton tied on points, immersing yourself into the story before the race starts.',
    href: '/seasons/2021/abu-dhabi-grand-prix/',
  },
  {
    label: 'Ferrari, 1996',
    title: 'Ferrari before Schumi',
    description:
      "Which footsteps did Schumi follow when joining Ferrari in 1996? Investigate the state of the Scuderia at the start of Schumacher's first season.",
    href: '/teams/ferrari/1996/preseason/',
  },
];
---

<Base
  title="Race Rewind - Formula 1 history, race by race"
  description="Explore Formula 1 history race by race. Driver career snapshots, standings as of any race, 1950-2026."
  canonical="/"
>
  <!-- Hero -->
  <div class="py-12 text-center sm:py-16">
    <h1 class="text-4xl font-extrabold tracking-tight text-fg sm:text-5xl lg:text-6xl">
      Race <span class="text-accent">Rewind</span>
    </h1>
    <p class="mx-auto mt-6 max-w-2xl text-lg text-fg-muted">
      Open Formula 1 history at the exact weekend it happened. Standings, lineups, stats and context
      stay locked to that moment, with future outcomes hidden.
    </p>

    <div class="mt-8">
      <ContinueButton {seasons} client:only="svelte" />
    </div>
  </div>

  <section class="mt-2">
    <div class="mb-5">
      <h2 class="text-2xl font-bold tracking-tight text-fg">
        Pick a moment before history happens
      </h2>
    </div>

    <div class="grid gap-4 md:grid-cols-2">
      {
        featuredMoments.map((moment) => (
          <a
            href={moment.href}
            class="group flex min-h-52 flex-col rounded-lg border border-border bg-bg-alt p-5 no-underline transition-all hover:border-accent hover:bg-bg-hover"
          >
            <span class="text-sm font-semibold uppercase tracking-wider text-accent">
              {moment.label}
            </span>
            <h3 class="mt-3 text-xl font-bold text-fg transition-colors group-hover:text-accent">
              {moment.title}
            </h3>
            <p class="mt-3 flex-1 text-sm leading-6 text-fg-muted">{moment.description}</p>
            <span class="mt-5 text-sm font-semibold text-fg transition-colors group-hover:text-accent">
              Open this weekend &rarr;
            </span>
          </a>
        ))
      }
    </div>
  </section>
</Base>
