---
import '../styles/app.css';
import TopNav from '../components/layout/TopNav.astro';
import TimeTravelBar from '../components/layout/TimeTravelBar.astro';
import Footer from '../components/layout/Footer.astro';
import { getAllRacesBySeason, getLatestRace } from '../lib/queries';
import { SITE_URL } from '../lib/const';
import { resolvePageNavState } from '../lib/page-nav';
import type { PageContext } from '../lib/types';

interface Props {
  title: string;
  description: string;
  canonical: string;
  lang?: string;
  robots?: string;
  pageContext?: PageContext;
}

const { title, description, canonical, lang = 'en', robots, pageContext } = Astro.props;
const canonicalURL = new URL(canonical, SITE_URL).href;

const [{ seasons, byseason }, latest] = await Promise.all([getAllRacesBySeason(), getLatestRace()]);

const { currentSeason, currentRaceSlug, currentChainSlug, compareSlug, section } =
  resolvePageNavState(pageContext, latest);
---

<!doctype html>
<html lang={lang} data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Anti-flash: read theme from localStorage before first paint -->
    <script is:inline>
      try {
        const t =
          localStorage.getItem('theme') ||
          (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', t);
        // eslint-disable-next-line no-empty
      } catch {}
    </script>

    <title>{title}</title>
    <meta name="description" content={description} />
    {robots && <meta name="robots" content={robots} />}
    <link rel="canonical" href={canonicalURL} />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
  </head>
  <body class="min-h-screen bg-bg font-sans text-fg antialiased">
    <div class="flex min-h-screen flex-col">
      <div class="sticky top-0 z-40">
        <TopNav
          {seasons}
          {byseason}
          {currentSeason}
          {currentRaceSlug}
          {currentChainSlug}
          {compareSlug}
          {section}
        />

        {pageContext && <TimeTravelBar {pageContext} />}
      </div>

      <main class="mx-auto w-full max-w-[var(--container-narrow)] flex-1 px-4 py-8 sm:px-6">
        <slot />
      </main>

      <Footer />
    </div>
  </body>
</html>
