---
import type { getAllDriverCareerStatsAsOf } from '../../lib/queries';
import { formatPts, driverLink } from '../../lib/format';

interface Props {
  drivers: Awaited<ReturnType<typeof getAllDriverCareerStatsAsOf>>;
  season: number;
  raceSlug: string;
}

const { drivers, season, raceSlug } = Astro.props;

function ordinal(n: number): string {
  const s = ['th', 'st', 'nd', 'rd'];
  const v = n % 100;
  return n + (s[(v - 20) % 10] || s[v] || s[0]);
}
---

{drivers.length > 0 && (
  <section class="mt-10">
    <h2 class="mb-3 border-b border-border pb-2 text-lg font-semibold text-fg">All Drivers with at Least One Start</h2>
    <div class="overflow-x-auto rounded-lg border border-border">
      <table class="w-full border-collapse text-sm">
        <thead>
          <tr>
            <th class="bg-bg-alt px-3 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-fg-muted border-b border-border whitespace-nowrap">Driver</th>
            <th class="bg-bg-alt px-3 py-2.5 text-right text-xs font-semibold uppercase tracking-wide text-fg-muted border-b border-border whitespace-nowrap">Seasons</th>
            <th class="bg-bg-alt px-3 py-2.5 text-right text-xs font-semibold uppercase tracking-wide text-fg-muted border-b border-border whitespace-nowrap">Starts</th>
            <th class="bg-bg-alt px-3 py-2.5 text-right text-xs font-semibold uppercase tracking-wide text-fg-muted border-b border-border whitespace-nowrap">Wins</th>
            <th class="bg-bg-alt px-3 py-2.5 text-right text-xs font-semibold uppercase tracking-wide text-fg-muted border-b border-border whitespace-nowrap">Podiums</th>
            <th class="bg-bg-alt px-3 py-2.5 text-right text-xs font-semibold uppercase tracking-wide text-fg-muted border-b border-border whitespace-nowrap">Points</th>
            <th class="bg-bg-alt px-3 py-2.5 text-right text-xs font-semibold uppercase tracking-wide text-fg-muted border-b border-border whitespace-nowrap">Best</th>
            <th class="bg-bg-alt px-3 py-2.5 text-right text-xs font-semibold uppercase tracking-wide text-fg-muted border-b border-border whitespace-nowrap">Champs</th>
          </tr>
        </thead>
        <tbody>
          {drivers.map((row) => (
            <tr class="border-b border-border last:border-0 hover:bg-bg-hover transition-colors">
              <td class="px-3 py-2.5">
                <a href={driverLink(row.driver_slug, season, raceSlug)} class="text-accent hover:underline font-medium">
                  {row.full_name}
                </a>
              </td>
              <td class="px-3 py-2.5 text-right tabular-nums text-fg-muted">{row.seasons}</td>
              <td class="px-3 py-2.5 text-right tabular-nums">{row.starts}</td>
              <td class="px-3 py-2.5 text-right tabular-nums font-medium">{row.wins}</td>
              <td class="px-3 py-2.5 text-right tabular-nums">{row.podiums}</td>
              <td class="px-3 py-2.5 text-right tabular-nums">{formatPts(row.points)}</td>
              <td class="px-3 py-2.5 text-right tabular-nums text-fg-muted text-xs">{row.best_championship_pos != null ? ordinal(row.best_championship_pos) : '—'}</td>
              <td class="px-3 py-2.5 text-right tabular-nums font-semibold {row.championships > 0 ? 'text-accent' : ''}">{row.championships}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
)}
