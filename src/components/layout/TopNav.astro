---
import ThemeToggle from '../primitives/ThemeToggle.svelte';
import SeasonDrawer from './SeasonDrawer.svelte';
import type { RaceNavEntry } from '../../lib/queries/races';

interface Props {
  seasons: number[];
  byseason: Record<number, RaceNavEntry[]>;
  currentSeason: number;
  currentRaceSlug?: string;
}

const { seasons, byseason, currentSeason, currentRaceSlug } = Astro.props;

const navLinks = [
  { href: '/seasons/', label: 'Seasons' },
  { href: '/drivers/', label: 'Drivers' },
  { href: '/teams/', label: 'Teams' },
  { href: '/compare/', label: 'Compare' },
];

const current = Astro.url.pathname;
---

<header class="sticky top-0 z-40 border-b border-border bg-bg/90 backdrop-blur-sm">
  <div class="mx-auto flex h-14 max-w-[var(--container-wide)] items-center gap-4 px-4 sm:px-6">
    <!-- Wordmark -->
    <a href="/" class="shrink-0 text-lg font-extrabold tracking-tight text-fg no-underline">
      F1 <span class="text-accent">History</span>
    </a>

    <!-- Primary nav (md+) -->
    <nav class="ml-6 hidden items-center gap-1 md:flex" aria-label="Primary">
      {navLinks.map(({ href, label }) => {
        const isActive = current.startsWith(href) && href !== '/';
        return (
          <a
            href={href}
            class={`rounded-md px-3 py-1.5 text-sm font-medium transition-colors no-underline ${isActive ? 'bg-bg-alt text-fg' : 'text-fg-muted hover:bg-bg-hover hover:text-fg'}`}
            aria-current={isActive ? 'page' : undefined}
          >
            {label}
          </a>
        );
      })}
    </nav>

    <!-- Right side controls -->
    <div class="ml-auto flex items-center gap-1">
      <ThemeToggle client:idle />
      <SeasonDrawer
        {seasons}
        {byseason}
        {currentSeason}
        {currentRaceSlug}
        client:idle
      />
    </div>
  </div>
</header>
