---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<div class="mb-8 border-b border-border pb-6">
  <h1 class="text-3xl font-bold tracking-tight text-fg sm:text-4xl">{title}</h1>
  {subtitle && <p class="mt-2 text-lg text-fg-muted">{subtitle}</p>}
  <slot />
</div>
