---
import { formatPts, formatDelta, teamLink } from '../../lib/format';

interface TeamRow {
  team_id: number;
  team_name: string;
  team_slug: string;
  position: number | null;
  points: number;
  win_count: number;
}

interface Props {
  title: string;
  rows: TeamRow[];
  season: number;
  raceSlug: string;
  prevPositions?: Map<number, number | null>;
}

const { title, rows, season, raceSlug, prevPositions } = Astro.props;
const showDelta = prevPositions != null;

const enriched = rows.map((row) => {
  const prevPos = prevPositions?.get(row.team_id) ?? null;
  const delta = showDelta ? formatDelta(prevPos, row.position) : null;
  const deltaClass = delta?.startsWith('+')
    ? 'text-up font-semibold'
    : delta?.startsWith('-')
      ? 'text-down font-semibold'
      : 'text-fg-muted';
  return { ...row, delta, deltaClass };
});
---

{rows.length > 0 && (
  <section class="mt-10">
    <h2 class="mb-3 border-b border-border pb-2 text-lg font-semibold text-fg">{title}</h2>
    <div class="overflow-x-auto rounded-lg border border-border">
      <table class="w-full border-collapse text-sm" data-sortable>
        <thead>
          <tr>
            <th data-sort-key="pos" class="bg-bg-alt px-3 py-2.5 text-right text-xs font-semibold uppercase tracking-wide text-fg-muted border-b border-border whitespace-nowrap w-10">Pos</th>
            {showDelta && <th class="bg-bg-alt px-2 py-2.5 text-right text-xs font-semibold uppercase tracking-wide text-fg-muted border-b border-border whitespace-nowrap w-8">Δ</th>}
            <th data-sort-key="team" class="bg-bg-alt px-3 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-fg-muted border-b border-border whitespace-nowrap">Team</th>
            <th data-sort-key="pts" class="bg-bg-alt px-3 py-2.5 text-right text-xs font-semibold uppercase tracking-wide text-fg-muted border-b border-border whitespace-nowrap">Pts</th>
            <th data-sort-key="wins" class="bg-bg-alt px-3 py-2.5 text-right text-xs font-semibold uppercase tracking-wide text-fg-muted border-b border-border whitespace-nowrap">Wins</th>
          </tr>
        </thead>
        <tbody>
          {enriched.map((row) => (
            <tr class="border-b border-border last:border-0 hover:bg-bg-hover transition-colors">
              <td class="px-3 py-2.5 text-right tabular-nums font-bold text-fg">{row.position ?? '—'}</td>
              {showDelta && <td class={`px-2 py-2.5 text-right tabular-nums text-xs ${row.deltaClass}`}>{row.delta}</td>}
              <td class="px-3 py-2.5">
                <a href={teamLink(row.team_slug, season, raceSlug)} class="text-accent hover:underline font-medium">
                  {row.team_name}
                </a>
              </td>
              <td class="px-3 py-2.5 text-right tabular-nums font-medium">{formatPts(row.points)}</td>
              <td class="px-3 py-2.5 text-right tabular-nums text-fg-muted">{row.win_count}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
)}

<script>
  import '../../scripts/sortable-table.ts';
</script>
