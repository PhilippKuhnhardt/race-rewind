---
import { raceFlag } from '../../lib/ui/emojify';

interface Props {
  name: string;
  season: number;
  round: number;
  raceCount: number;
  date: string;
  circuitName: string;
  circuitLocality: string | null;
  circuitCountry: string | null;
}

const { name, season, round, raceCount, date, circuitName, circuitLocality, circuitCountry } =
  Astro.props;
const circuitFlag = circuitCountry ? raceFlag(circuitCountry) : null;
const countryLabel = circuitCountry ?? null;
const mobilePlace = [circuitLocality, countryLabel].filter(Boolean).join(', ');
const placeLabel = mobilePlace ? `${circuitFlag ? `${circuitFlag} ` : ''}${mobilePlace}` : null;
const desktopPlace = [circuitName, circuitLocality, countryLabel].filter(Boolean).join(', ');
const desktopLocation = `${circuitFlag ? `${circuitFlag} ` : ''}${desktopPlace}`;
---

<div class="mb-6">
  <h1 class="text-3xl font-bold tracking-tight text-fg sm:text-4xl">
    {season}
    {name}
  </h1>
  <div
    class="mt-2 flex flex-col items-start gap-1 text-sm text-fg-muted sm:flex-row sm:flex-wrap sm:items-center sm:gap-x-3 sm:gap-y-1"
  >
    <span class="hidden sm:inline">{desktopLocation}</span>
    <span class="sm:hidden">{circuitName}</span>
    {placeLabel && <span class="sm:hidden">{placeLabel}</span>}
    <span class="hidden sm:inline" aria-hidden="true">·</span>
    <time datetime={date}>{date}</time>
    <span class="hidden sm:inline" aria-hidden="true">·</span>
    <span>Round {round} of {raceCount}</span>
  </div>
</div>
