---
import { formatPts, driverLink, teamLink } from '../../lib/format';

interface Props {
  driverLeader: { full_name: string; driver_slug: string; points: number; gap: number } | null;
  teamLeader: { team_name: string; team_slug: string; points: number; gap: number } | null;
  season: number;
  raceSlug: string;
}

const { driverLeader, teamLeader, season, raceSlug } = Astro.props;

if (!driverLeader && !teamLeader) return;
---

<section>
  <h2 class="mb-4 text-lg font-semibold text-fg">Going Into This Race</h2>
  <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
    {driverLeader && (
      <div class="rounded-xl border border-border bg-bg-alt p-4">
        <div class="mb-1 text-xs font-semibold uppercase tracking-wide text-fg-muted">WDC Leader</div>
        <div class="font-semibold text-fg">
          <a href={driverLink(driverLeader.driver_slug, season, raceSlug)} class="text-accent hover:underline no-underline">
            {driverLeader.full_name}
          </a>
        </div>
        <div class="mt-1 text-sm text-fg-muted">
          {formatPts(driverLeader.points)} pts
          {driverLeader.gap > 0 && <span class="ml-1 text-xs">(+{formatPts(driverLeader.gap)} over P2)</span>}
        </div>
      </div>
    )}
    {teamLeader && (
      <div class="rounded-xl border border-border bg-bg-alt p-4">
        <div class="mb-1 text-xs font-semibold uppercase tracking-wide text-fg-muted">WCC Leader</div>
        <div class="font-semibold text-fg">
          <a href={teamLink(teamLeader.team_slug, season, raceSlug)} class="text-accent hover:underline no-underline">
            {teamLeader.team_name}
          </a>
        </div>
        <div class="mt-1 text-sm text-fg-muted">
          {formatPts(teamLeader.points)} pts
          {teamLeader.gap > 0 && <span class="ml-1 text-xs">(+{formatPts(teamLeader.gap)} over P2)</span>}
        </div>
      </div>
    )}
  </div>
</section>
