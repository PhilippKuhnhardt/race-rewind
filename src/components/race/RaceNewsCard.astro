---
import type { RaceNewsEntry } from '../../lib/race-news';

interface Props {
  entry: RaceNewsEntry;
  heading?: string;
}

const { entry, heading } = Astro.props;
const { source_url, source_title, license, phase } = entry.data;

const defaultHeading =
  phase === 'preseason'
    ? 'Before the season'
    : phase === 'postseason'
      ? 'Season summary'
      : 'Pre-Race Report';
---

<section>
  <h2 class="mb-4 text-lg font-semibold text-fg">{heading ?? defaultHeading}</h2>
  <div
    class="text-fg leading-relaxed
           [&_p]:my-3
           [&_h3]:text-base [&_h3]:font-semibold [&_h3]:text-fg [&_h3]:mt-6 [&_h3]:mb-2
           [&_a]:text-accent [&_a]:hover:underline
           [&_ul]:list-disc [&_ul]:pl-5 [&_ul]:my-3
           [&_ol]:list-decimal [&_ol]:pl-5 [&_ol]:my-3
           [&_li]:my-1
           [&_strong]:font-semibold [&_strong]:text-fg
           [&_>:first-child]:mt-0"
  >
    <Fragment set:html={entry.rendered?.html ?? ''} />
  </div>
  <p class="mt-6 text-xs text-fg-muted">
    Adapted by AI summarisation from
    <a href={source_url} class="text-accent hover:underline" rel="noopener">
      &ldquo;{source_title}&rdquo; on Wikipedia
    </a>. This adapted text is licensed under
    <a
      href="https://creativecommons.org/licenses/by-sa/4.0/"
      class="text-accent hover:underline"
      rel="noopener license"
    >
      {license}
    </a>. Modifications: summarised and spoiler-trimmed.
  </p>
</section>
