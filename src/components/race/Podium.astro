---
import { driverLink, teamLink } from '../../lib/format';

interface PodiumRow {
  position: number | null;
  driver_slug: string;
  full_name: string;
  team_slug: string | null;
  team_name: string | null;
  time: string | null;
}

interface Props {
  podium: PodiumRow[];
  season: number;
  raceSlug: string;
}

const { podium, season, raceSlug } = Astro.props;

const groups: PodiumRow[][] = [];
const indexByPosition = new Map<number, number>();
for (const row of podium) {
  const pos = row.position ?? 0;
  const existing = indexByPosition.get(pos);
  if (existing === undefined) {
    indexByPosition.set(pos, groups.length);
    groups.push([row]);
  } else {
    groups[existing].push(row);
  }
}
---

{groups.length > 0 && (
  <section>
    <h2 class="mb-4 text-lg font-semibold text-fg">Podium</h2>
    <div class="grid grid-cols-1 gap-3 sm:grid-cols-3">
      {groups.map((group) => {
        const head = group[0];
        return (
          <div class={`rounded-xl border p-4 ${head.position === 1 ? 'border-accent/30 bg-accent/5' : 'border-border bg-bg-alt'}`}>
            <div class="mb-1 text-3xl font-black tabular-nums text-fg-muted">P{head.position}</div>
            {group.map((row, i) => (
              <div class={i > 0 ? 'mt-3 border-t border-border pt-3' : ''}>
                <div class="font-semibold text-fg">
                  <a href={driverLink(row.driver_slug, season, raceSlug)} class="text-accent hover:underline no-underline">
                    {row.full_name}
                  </a>
                </div>
                <div class="mt-0.5 text-sm text-fg-muted">
                  {row.team_slug
                    ? <a href={teamLink(row.team_slug, season, raceSlug)} class="text-fg-muted hover:underline no-underline">{row.team_name}</a>
                    : <span>{row.team_name}</span>
                  }
                </div>
                {row.time && <div class="mt-2 font-mono text-xs text-fg-muted">{row.time}</div>}
              </div>
            ))}
          </div>
        );
      })}
    </div>
  </section>
)}
