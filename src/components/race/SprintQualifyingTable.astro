---
import { driverLink, teamLink, formatQualifyingTime } from '../../lib/format';
import type { getSprintQualifyingResults } from '../../lib/queries';

interface Props {
  sprintQuali: Awaited<ReturnType<typeof getSprintQualifyingResults>>;
  season: number;
  raceSlug: string;
}

const { sprintQuali, season, raceSlug } = Astro.props;
---

{sprintQuali.length > 0 ? (
  <div class="overflow-x-auto rounded-lg border border-border">
    <table class="w-full border-collapse text-sm" data-sortable>
      <thead>
        <tr>
          <th data-sort-key="pos" class="bg-bg-alt px-3 py-2.5 text-right text-xs font-semibold uppercase tracking-wide text-fg-muted border-b border-border whitespace-nowrap w-10">Pos</th>
          <th data-sort-key="driver" class="bg-bg-alt px-3 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-fg-muted border-b border-border whitespace-nowrap">Driver</th>
          <th data-sort-key="team" class="bg-bg-alt px-3 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-fg-muted border-b border-border whitespace-nowrap">Team</th>
          <th data-sort-key="sq1" class="bg-bg-alt px-3 py-2.5 text-right text-xs font-semibold uppercase tracking-wide text-fg-muted border-b border-border whitespace-nowrap font-mono">SQ1</th>
          <th data-sort-key="sq2" class="bg-bg-alt px-3 py-2.5 text-right text-xs font-semibold uppercase tracking-wide text-fg-muted border-b border-border whitespace-nowrap font-mono">SQ2</th>
          <th data-sort-key="sq3" class="bg-bg-alt px-3 py-2.5 text-right text-xs font-semibold uppercase tracking-wide text-fg-muted border-b border-border whitespace-nowrap font-mono">SQ3</th>
        </tr>
      </thead>
      <tbody>
        {sprintQuali.map((row) => (
          <tr class="border-b border-border last:border-0 hover:bg-bg-hover transition-colors">
            <td class="px-3 py-2.5 text-right tabular-nums font-bold text-fg">{row.position ?? '—'}</td>
            <td class="px-3 py-2.5">
              <a href={driverLink(row.driver_slug, season, raceSlug)} class="text-accent hover:underline font-medium">{row.full_name}</a>
            </td>
            <td class="px-3 py-2.5 text-fg-muted">
              <a href={teamLink(row.team_slug, season, raceSlug)} class="text-fg-muted hover:text-accent hover:underline">{row.team_name}</a>
            </td>
            <td class="px-3 py-2.5 text-right font-mono text-xs tabular-nums">{formatQualifyingTime(row.sq1_time)}</td>
            <td class="px-3 py-2.5 text-right font-mono text-xs tabular-nums">{formatQualifyingTime(row.sq2_time)}</td>
            <td class="px-3 py-2.5 text-right font-mono text-xs tabular-nums">{formatQualifyingTime(row.sq3_time)}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
) : (
  <p class="text-sm text-fg-muted">No sprint qualifying data available.</p>
)}

<script>
  import '../../scripts/sortable-table.ts';
</script>
