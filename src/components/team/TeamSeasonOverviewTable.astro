---
import type { getTeamSeasonOverview } from '../../lib/queries';
import { formatPts, ordinal } from '../../lib/format';
import { teamLinkAt } from '../../lib/nav';
import { pitForPostseason, type PointInTime } from '../../lib/point-in-time';

interface Props {
  teamSlug: string;
  rows: Awaited<ReturnType<typeof getTeamSeasonOverview>>;
  pit: PointInTime;
  title?: string;
}

const { teamSlug, rows, pit, title = 'Season Overview' } = Astro.props;

function pitForRowSeason(season: number): PointInTime {
  return season === pit.season ? pit : pitForPostseason(season);
}
---

{rows.length > 0 && (
  <section class="mb-6">
    <h2 class="mb-4 text-lg font-semibold text-fg">{title}</h2>
    <div class="overflow-x-auto rounded-lg border border-border">
      <table class="w-full border-collapse text-sm" data-sortable>
        <thead>
          <tr>
            <th data-sort-key="season" class="bg-bg-alt px-3 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-fg-muted border-b border-border whitespace-nowrap">Season</th>
            <th data-sort-key="grand-prix" class="bg-bg-alt px-3 py-2.5 text-right text-xs font-semibold uppercase tracking-wide text-fg-muted border-b border-border whitespace-nowrap">GPs</th>
            <th data-sort-key="wins" class="bg-bg-alt px-3 py-2.5 text-right text-xs font-semibold uppercase tracking-wide text-fg-muted border-b border-border whitespace-nowrap">Wins</th>
            <th data-sort-key="podiums" class="bg-bg-alt px-3 py-2.5 text-right text-xs font-semibold uppercase tracking-wide text-fg-muted border-b border-border whitespace-nowrap">Podiums</th>
            <th data-sort-key="poles" class="bg-bg-alt px-3 py-2.5 text-right text-xs font-semibold uppercase tracking-wide text-fg-muted border-b border-border whitespace-nowrap">Poles</th>
            <th data-sort-key="points" class="bg-bg-alt px-3 py-2.5 text-right text-xs font-semibold uppercase tracking-wide text-fg-muted border-b border-border whitespace-nowrap">Points</th>
            <th data-sort-key="championship" class="bg-bg-alt px-3 py-2.5 text-right text-xs font-semibold uppercase tracking-wide text-fg-muted border-b border-border whitespace-nowrap">Championship</th>
          </tr>
        </thead>
        <tbody>
          {rows.map((row) => {
            const rowPit = pitForRowSeason(row.season);
            return (
              <tr class="border-b border-border last:border-0 hover:bg-bg-hover transition-colors">
                <td class="px-3 py-2.5 font-medium tabular-nums">
                  <a href={teamLinkAt(teamSlug, rowPit)} class="text-accent hover:underline">
                    {row.season}
                  </a>
                </td>
                <td class="px-3 py-2.5 text-right tabular-nums text-fg">{row.grand_prix}</td>
                <td class="px-3 py-2.5 text-right tabular-nums text-fg">{row.wins}</td>
                <td class="px-3 py-2.5 text-right tabular-nums text-fg">{row.podiums}</td>
                <td class="px-3 py-2.5 text-right tabular-nums text-fg">{row.poles}</td>
                <td class="px-3 py-2.5 text-right tabular-nums text-fg">{formatPts(row.points)}</td>
                <td class="px-3 py-2.5 text-right tabular-nums text-fg-muted" data-sort-value={row.championship_position ?? ''}>
                  {row.championship_position != null ? ordinal(row.championship_position) : '—'}
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  </section>
)}

<script>
  import '../../scripts/sortable-table.ts';
</script>
