---
import { formatPts } from '../../lib/format';
import type { getDriverTeamsDriven } from '../../lib/queries';
import TeamColorSwatch from '../primitives/TeamColorSwatch.astro';

interface Props {
  teams: Awaited<ReturnType<typeof getDriverTeamsDriven>>;
  teamHref?: (slug: string) => string;
}

const { teams, teamHref = (slug) => `/teams/?slug=${encodeURIComponent(slug)}` } = Astro.props;
---

{teams.length > 0 && (
  <section class="mb-6">
    <h2 class="mb-4 text-lg font-semibold text-fg">Teams Driven For</h2>
    <div class="overflow-x-auto rounded-lg border border-border">
      <table class="w-full border-collapse text-sm" data-sortable>
        <thead>
          <tr>
            <th data-sort-key="team" class="bg-bg-alt px-3 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-fg-muted border-b border-border whitespace-nowrap">Team</th>
            <th data-sort-key="years" class="bg-bg-alt px-3 py-2.5 text-left text-xs font-semibold uppercase tracking-wide text-fg-muted border-b border-border whitespace-nowrap">Years</th>
            <th data-sort-key="starts" class="bg-bg-alt px-3 py-2.5 text-right text-xs font-semibold uppercase tracking-wide text-fg-muted border-b border-border whitespace-nowrap">Starts</th>
            <th data-sort-key="wins" class="bg-bg-alt px-3 py-2.5 text-right text-xs font-semibold uppercase tracking-wide text-fg-muted border-b border-border whitespace-nowrap">Wins</th>
            <th data-sort-key="points" class="bg-bg-alt px-3 py-2.5 text-right text-xs font-semibold uppercase tracking-wide text-fg-muted border-b border-border whitespace-nowrap">Points</th>
            <th data-sort-key="wdc" class="bg-bg-alt px-3 py-2.5 text-right text-xs font-semibold uppercase tracking-wide text-fg-muted border-b border-border whitespace-nowrap">WDC</th>
            <th data-sort-key="wcc" class="bg-bg-alt px-3 py-2.5 text-right text-xs font-semibold uppercase tracking-wide text-fg-muted border-b border-border whitespace-nowrap">WCC</th>
          </tr>
        </thead>
        <tbody>
          {teams.map((t) => (
            <tr class="border-b border-border last:border-0 hover:bg-bg-hover transition-colors">
              <td class="px-3 py-2.5">
                <span class="inline-flex items-center gap-2">
                  <TeamColorSwatch slug={t.team_slug} season={t.color_season} variant="dot" />
                  <a href={teamHref(t.team_slug)} class="text-accent hover:underline font-medium">
                    {t.name}
                  </a>
                </span>
              </td>
              <td class="px-3 py-2.5 text-fg-muted whitespace-nowrap">{t.years}</td>
              <td class="px-3 py-2.5 text-right tabular-nums text-fg">{t.starts}</td>
              <td class="px-3 py-2.5 text-right tabular-nums text-fg">{t.wins}</td>
              <td class="px-3 py-2.5 text-right tabular-nums text-fg">{formatPts(t.points)}</td>
              <td class="px-3 py-2.5 text-right tabular-nums text-fg-muted">{t.driver_championships || '—'}</td>
              <td class="px-3 py-2.5 text-right tabular-nums text-fg-muted">{t.team_championships || '—'}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
)}

<script>
  import '../../scripts/sortable-table.ts';
</script>
